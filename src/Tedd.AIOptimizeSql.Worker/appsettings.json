{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "OptimizeEngine": {
    "QueuePollIntervalSeconds": 10,
    "BatchStateCheckIntervalSeconds": 5,
    "MaxToolResponseBytes": 524288
  },
  "ConnectionStrings": {
    "AIOptimizeDb": "Server=(localdb)\\MSSQLLocalDB;Database=AIOptimizeSql;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  }
}
