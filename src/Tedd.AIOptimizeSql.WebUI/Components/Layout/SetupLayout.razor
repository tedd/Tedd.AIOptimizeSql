@inherits LayoutComponentBase

<MudThemeProvider @bind-IsDarkMode="_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="4" Dense="true">
        <MudIcon Icon="@Icons.Material.Filled.Storage" Class="mr-2" />
        <MudText Typo="Typo.h6">Database setup</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Material.Filled.DarkMode" Color="Color.Inherit"
                       OnClick="@ToggleDarkMode" aria-label="Toggle dark mode" />
    </MudAppBar>

    <MudMainContent>
        <div class="pa-4">
            @Body
        </div>
    </MudMainContent>
</MudLayout>

@code {
    private bool _isDarkMode = true;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1976D2",
            Secondary = "#7C4DFF",
            AppbarBackground = "#1565C0",
            Background = "#f5f5f5",
            Surface = "#ffffff",
            DrawerBackground = "#ffffff",
            DrawerText = "#424242",
            Success = "#2E7D32",
            Warning = "#F57C00",
            Error = "#D32F2F",
            Info = "#0288D1"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#42A5F5",
            Secondary = "#B388FF",
            AppbarBackground = "#0D47A1",
            Background = "#121212",
            Surface = "#1E1E1E",
            DrawerBackground = "#1a1a2e",
            DrawerText = "#e0e0e0",
            Success = "#66BB6A",
            Warning = "#FFA726",
            Error = "#EF5350",
            Info = "#29B6F6"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = ["Inter", "Helvetica", "Arial", "sans-serif"]
            }
        }
    };

    private void ToggleDarkMode() => _isDarkMode = !_isDarkMode;
}
