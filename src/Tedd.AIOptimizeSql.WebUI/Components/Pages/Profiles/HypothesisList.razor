@page "/profiles/{ExperimentId:int}/research-iterations/{IterationId:int}"
@implements IDisposable
@rendermode InteractiveServer
@inject IDbContextFactory<Tedd.AIOptimizeSql.Database.AIOptimizeDbContext> DbContextFactory
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@using Microsoft.EntityFrameworkCore
@using Tedd.AIOptimizeSql.Database

<PageTitle>Hypotheses</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-2">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                       OnClick="@(() => Navigation.NavigateTo($"/profiles/{ExperimentId}/research-iterations"))" />
        <MudText Typo="Typo.h4">Hypotheses</MudText>
        <MudSpacer />
        @if (_selectedItems.Count > 0)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete"
                       OnClick="DeleteSelected" Class="mr-2">
                Delete Selected (@_selectedItems.Count)
            </MudButton>
        }
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   Href="@($"/experiments/{ExperimentId}/research-iterations/{IterationId}/hypotheses/new")">
            New Hypothesis
        </MudButton>
    </MudStack>

    @if (_iteration != null)
    {
        <MudText Typo="Typo.subtitle1" Class="mb-4" Color="Color.Default">
            Iteration #@((int)(object)_iteration.Id) &mdash; Created @_iteration.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")
            @if (!string.IsNullOrEmpty(_iteration.Hints))
            {
                <text> &mdash; @_iteration.Hints</text>
            }
        </MudText>
    }

    @if (_stats != null)
    {
        <MudGrid Class="mb-4">
            <MudItem xs="12" sm="3">
                <MudPaper Elevation="2" Class="pa-4 rounded-lg d-flex flex-column align-center">
                    <MudText Typo="Typo.h4" Color="Color.Primary">@_stats.TotalHypotheses</MudText>
                    <MudText Typo="Typo.caption">Total Hypotheses</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudPaper Elevation="2" Class="pa-4 rounded-lg d-flex flex-column align-center">
                    <MudText Typo="Typo.h4" Color="Color.Success">@_stats.Improvements</MudText>
                    <MudText Typo="Typo.caption">Improvements</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudPaper Elevation="2" Class="pa-4 rounded-lg d-flex flex-column align-center">
                    <MudText Typo="Typo.h4" Color="Color.Error">@_stats.Regressions</MudText>
                    <MudText Typo="Typo.caption">Regressions</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudPaper Elevation="2" Class="pa-4 rounded-lg d-flex flex-column align-center">
                    <MudText Typo="Typo.h4" Color="Color.Info">@FormatTime(_stats.TotalTimeMs)</MudText>
                    <MudText Typo="Typo.caption">Total Time</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }

    @if (_hypothesisChartSeries.Count > 0)
    {
        <MudCard Elevation="3" Class="rounded-lg mb-4">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Improvement % per Hypothesis</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudChart T="double" ChartType="ChartType.Bar"
                          ChartSeries="@_hypothesisChartSeries"
                          x-axis-labels="@_chartLabels" Width="100%" Height="250px" />
            </MudCardContent>
        </MudCard>
    }

    <MudTable @ref="_table" T="Hypothesis" ServerData="LoadServerData" Hover="true" Elevation="3"
              Dense="true" FixedHeader="true" MultiSelection="true" @bind-SelectedItems="_selectedItems"
              OnRowClick="OnRowClick" RowClass="cursor-pointer" Class="rounded-lg">
        <HeaderContent>
            <MudTh><MudTableSortLabel SortLabel="Id" T="Hypothesis">#</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="Hypothesis" T="Hypothesis">Hypothesis</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="Improvement" T="Hypothesis">Improvement</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="AiProvider" T="Hypothesis">AI Provider</MudTableSortLabel></MudTh>
            <MudTh>Model</MudTh>
            <MudTh>Builds On</MudTh>
            <MudTh><MudTableSortLabel SortLabel="TimeUsedMs" T="Hypothesis">Time Used</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="CreatedAt" T="Hypothesis">Created</MudTableSortLabel></MudTh>
            <MudTh Style="width: 80px;">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="#">@((int)(object)context.Id)</MudTd>
            <MudTd DataLabel="Hypothesis">
                <MudText Typo="Typo.body2" Style="max-width:300px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                    @(context.Description ?? "--")
                </MudText>
            </MudTd>
            <MudTd DataLabel="Improvement">
                @{
                    var pct = context.ImpovementPercentage;
                    var deltaColor = pct > 0 ? Color.Success : (pct < 0 ? Color.Error : Color.Default);
                }
                <MudChip T="string" Size="Size.Small" Color="@deltaColor">
                    @(pct >= 0 ? "+" : "")@pct.ToString("F1")%
                </MudChip>
            </MudTd>
            <MudTd DataLabel="AI Provider">@(_iteration?.AiProviderUsed?.ToString() ?? "--")</MudTd>
            <MudTd DataLabel="Model">@(_iteration?.AiModelUsed ?? "--")</MudTd>
            <MudTd DataLabel="Builds On">
                @if (context.BuildsOnHypothesisId.HasValue)
                {
                    <MudLink Href="@($"/experiments/{ExperimentId}/research-iterations/{IterationId}/hypotheses/{(int)(object)context.BuildsOnHypothesisId}")"
                             Color="Color.Primary">
                        #@((int)(object)context.BuildsOnHypothesisId)
                    </MudLink>
                }
                else
                {
                    <MudText Typo="Typo.body2">--</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Time Used">@FormatTime(context.TimeUsedMs)</MudTd>
            <MudTd DataLabel="Created">@context.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                               OnClick="@(() => DeleteSingle(context))" aria-label="Delete" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body1" Class="pa-4">No hypotheses found for this research iteration.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 20, 50, 100 }" />
        </PagerContent>
    </MudTable>
</MudContainer>

@code {
    [Parameter] public int ExperimentId { get; set; }
    [Parameter] public int IterationId { get; set; }

    private readonly CancellationTokenSource _pageCts = new();
    private ResearchIteration? _iteration;
    private MudTable<Hypothesis>? _table;
    private HashSet<Hypothesis> _selectedItems = new();
    private ResearchIterationRunStatsViewModel? _stats;
    private string[] _chartLabels = Array.Empty<string>();
    private List<ChartSeries<double>> _hypothesisChartSeries = new();

    public void Dispose()
    {
        _pageCts.Cancel();
        _pageCts.Dispose();
    }

    protected override Task OnInitializedAsync() =>
        PageLoadCancellation.RunPageLoadAsync(async ct =>
        {
            await using var db = await DbContextFactory.CreateDbContextAsync(ct);
            var iterationId = (ResearchIterationId)(object)IterationId;
            _iteration = await db.ResearchIterations.AsNoTracking().FirstOrDefaultAsync(r => r.Id == iterationId, ct);
            await LoadStats(db, ct);
            await LoadChartData(db, ct);
        }, _pageCts.Token);

    private async Task LoadStats(AIOptimizeDbContext db, CancellationToken cancellationToken = default)
    {
        var iterationId = (ResearchIterationId)(object)IterationId;
        var hypotheses = await db.Hypotheses
            .Where(h => h.ResearchIterationId == iterationId)
            .ToListAsync(cancellationToken);

        _stats = ResearchIterationRunStatsMapper.ToViewModel(new ResearchIterationRunStatsSource(
            hypotheses.Count,
            hypotheses.Count(h => h.ImpovementPercentage > 0),
            hypotheses.Count(h => h.ImpovementPercentage < 0),
            hypotheses.Sum(h => h.TimeUsedMs)));
    }

    private async Task LoadChartData(AIOptimizeDbContext db, CancellationToken cancellationToken = default)
    {
        var iterationId = (ResearchIterationId)(object)IterationId;
        var hypotheses = await db.Hypotheses
            .Where(h => h.ResearchIterationId == iterationId)
            .OrderBy(h => h.CreatedAt)
            .Select(h => new { h.ImpovementPercentage, h.Id })
            .ToListAsync(cancellationToken);

        var data = hypotheses.Select(h => (double)h.ImpovementPercentage).ToList();
        _chartLabels = hypotheses.Select(h => $"#{(int)(object)h.Id}").ToArray();
        _hypothesisChartSeries = data.Count == 0
            ? new List<ChartSeries<double>>()
            : new List<ChartSeries<double>> { new() { Name = "Improvement %", Data = data } };
    }

    private string FormatTime(long ms)
    {
        if (ms < 1000) return $"{ms}ms";
        if (ms < 60000) return $"{ms / 1000.0:F1}s";
        return $"{ms / 60000.0:F1}m";
    }

    private Task<TableData<Hypothesis>> LoadServerData(TableState state, CancellationToken ct) =>
        PageLoadCancellation.RunTableLoadAsync(t => LoadServerDataCore(state, t), _pageCts.Token, ct);

    private async Task<TableData<Hypothesis>> LoadServerDataCore(TableState state, CancellationToken cancellationToken)
    {
        await using var db = await DbContextFactory.CreateDbContextAsync(cancellationToken);
        var iterationId = (ResearchIterationId)(object)IterationId;

        IQueryable<Hypothesis> query = db.Hypotheses
            .Where(h => h.ResearchIterationId == iterationId);

        query = state.SortLabel switch
        {
            "Id" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.Id) : query.OrderBy(x => x.Id),
            "Hypothesis" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.Description) : query.OrderBy(x => x.Description),
            "Improvement" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.ImpovementPercentage) : query.OrderBy(x => x.ImpovementPercentage),
            "AiProvider" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.ResearchIteration!.AiProviderUsed) : query.OrderBy(x => x.ResearchIteration!.AiProviderUsed),
            "TimeUsedMs" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.TimeUsedMs) : query.OrderBy(x => x.TimeUsedMs),
            "CreatedAt" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.CreatedAt) : query.OrderBy(x => x.CreatedAt),
            _ => query.OrderByDescending(x => x.CreatedAt)
        };

        var totalItems = await query.CountAsync(cancellationToken);
        var items = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).ToListAsync(cancellationToken);

        return new TableData<Hypothesis> { TotalItems = totalItems, Items = items };
    }

    private void OnRowClick(TableRowClickEventArgs<Hypothesis> args)
    {
        Navigation.NavigateTo($"/experiments/{ExperimentId}/research-iterations/{IterationId}/hypotheses/{(int)(object)args.Item!.Id}");
    }

    private async Task DeleteSingle(Hypothesis item)
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Confirm Delete",
            "Delete this hypothesis?",
            yesText: "Delete", cancelText: "Cancel");

        if (confirm == true)
        {
            await using var db = await DbContextFactory.CreateDbContextAsync();
            await NullOutBuildsOnReferences(db, item.Id);
            var deleted = await db.Hypotheses.Where(h => h.Id == item.Id).ExecuteDeleteAsync();
            if (deleted == 0)
                return;
            Snackbar.Add("Hypothesis deleted", Severity.Success);
            await _table!.ReloadServerData();
            await RefreshStatsAndChartAfterMutationAsync();
        }
    }

    private async Task DeleteSelected()
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Confirm Delete",
            $"Delete {_selectedItems.Count} hypothesis/hypotheses?",
            yesText: "Delete All", cancelText: "Cancel");

        if (confirm == true)
        {
            var ids = _selectedItems.Select(i => i.Id).ToList();
            await using var db = await DbContextFactory.CreateDbContextAsync();
            await db.Hypotheses
                .Where(h => h.BuildsOnHypothesisId != null && ids.Contains(h.BuildsOnHypothesisId.Value))
                .ExecuteUpdateAsync(s => s.SetProperty(h => h.BuildsOnHypothesisId, (HypothesisId?)null));
            var deleted = await db.Hypotheses.Where(h => ids.Contains(h.Id)).ExecuteDeleteAsync();
            Snackbar.Add(deleted == 0 ? "Nothing deleted" : $"Deleted {deleted} hypothesis/hypotheses", deleted == 0 ? Severity.Info : Severity.Success);
            _selectedItems.Clear();
            await _table!.ReloadServerData();
            await RefreshStatsAndChartAfterMutationAsync();
        }
    }

    private static Task NullOutBuildsOnReferences(AIOptimizeDbContext db, HypothesisId id) =>
        db.Hypotheses
            .Where(h => h.BuildsOnHypothesisId == id)
            .ExecuteUpdateAsync(s => s.SetProperty(h => h.BuildsOnHypothesisId, (HypothesisId?)null));

    private async Task RefreshStatsAndChartAfterMutationAsync()
    {
        await using var db = await DbContextFactory.CreateDbContextAsync();
        await LoadStats(db, _pageCts.Token);
        await LoadChartData(db, _pageCts.Token);
    }
}
