@page "/profiles/{ExperimentId:int}/runs"
@rendermode InteractiveServer
@inject Tedd.AIOptimizeSql.Database.AIOptimizeDbContext DbContext
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@using Microsoft.EntityFrameworkCore

<PageTitle>Optimization Runs</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                       OnClick="@(() => Navigation.NavigateTo("/profiles"))" />
        <MudText Typo="Typo.h4">
            Runs for: @(_profile?.Name ?? "...")
        </MudText>
        <MudSpacer />
        @if (_selectedItems.Count > 0)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete"
                       OnClick="DeleteSelected" Class="mr-2">
                Delete Selected (@_selectedItems.Count)
            </MudButton>
        }
        <MudButton Variant="Variant.Text" Color="Color.Primary"
                   Href="@($"/profiles/{ExperimentId}/edit")" StartIcon="@Icons.Material.Filled.Edit" Class="mr-2">
            Edit Profile
        </MudButton>
    </MudStack>

    @if (_runChartSeries.Count > 0)
    {
        <MudCard Elevation="3" Class="rounded-lg mb-4">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Hypothesis improvement %</MudText>
                    <MudText Typo="Typo.caption">Positive = improvement, Negative = regression</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudChart T="double" ChartType="ChartType.Bar" ChartSeries="@_runChartSeries"
                          x-axis-labels="@_chartLabels" Width="100%" Height="300px" />
            </MudCardContent>
        </MudCard>
    }

    <MudTable @ref="_table" T="HypothesisBatchRunRowViewModel" ServerData="LoadServerData" Hover="true" Elevation="3"
              Dense="true" FixedHeader="true" MultiSelection="true" @bind-SelectedItems="_selectedItems"
              OnRowClick="OnRowClick" RowClass="cursor-pointer" Class="rounded-lg">
        <HeaderContent>
            <MudTh><MudTableSortLabel SortLabel="Id" T="HypothesisBatchRunRowViewModel">Run #</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="Hypotheses" T="HypothesisBatchRunRowViewModel">Hypotheses</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="TotalTime" T="HypothesisBatchRunRowViewModel">Total Time</MudTableSortLabel></MudTh>
            <MudTh>Hints</MudTh>
            <MudTh><MudTableSortLabel SortLabel="CreatedAt" T="HypothesisBatchRunRowViewModel">Created</MudTableSortLabel></MudTh>
            <MudTh Style="width: 80px;">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Run #">@((int)(object)context.Run.Id)</MudTd>
            <MudTd DataLabel="Hypotheses">
                <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.HypothesisCount</MudChip>
            </MudTd>
            <MudTd DataLabel="Total Time">@FormatTime(context.TotalTimeMs)</MudTd>
            <MudTd DataLabel="Hints">
                <MudText Typo="Typo.body2" Style="max-width:300px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                    @(context.Run.Hints ?? "--")
                </MudText>
            </MudTd>
            <MudTd DataLabel="Created">@context.Run.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                               OnClick="@(() => DeleteSingle(context))" aria-label="Delete" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body1" Class="pa-4">No optimization runs found.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 20, 50, 100 }" />
        </PagerContent>
    </MudTable>
</MudContainer>

@code {
    [Parameter] public int ExperimentId { get; set; }

    private Experiment? _profile;
    private MudTable<HypothesisBatchRunRowViewModel>? _table;
    private HashSet<HypothesisBatchRunRowViewModel> _selectedItems = new();
    private string[] _chartLabels = Array.Empty<string>();
    private List<ChartSeries<double>> _runChartSeries = new();

    protected override async Task OnInitializedAsync()
    {
        var experimentId = (ExperimentId)(object)ExperimentId;
        _profile = await DbContext.Experiments.FindAsync(experimentId);
        await LoadChartData();
    }

    private async Task LoadChartData()
    {
        var experimentId = (ExperimentId)(object)ExperimentId;
        var hypotheses = await DbContext.Hypotheses
            .Where(h => h.HypothesisBatch!.ExperimentId == experimentId)
            .OrderBy(h => h.CreatedAt)
            .Select(h => new { h.ImpovementPercentage, h.CreatedAt })
            .Take(50)
            .ToListAsync();

        var data = hypotheses.Select(h => (double)h.ImpovementPercentage).ToList();
        _chartLabels = hypotheses.Select((h, i) => $"H{i + 1}").ToArray();
        _runChartSeries = data.Count == 0
            ? new List<ChartSeries<double>>()
            : new List<ChartSeries<double>> { new() { Name = "Improvement %", Data = data } };
    }

    private string FormatTime(long ms)
    {
        if (ms < 1000) return $"{ms}ms";
        if (ms < 60000) return $"{ms / 1000.0:F1}s";
        return $"{ms / 60000.0:F1}m";
    }

    private async Task<TableData<HypothesisBatchRunRowViewModel>> LoadServerData(TableState state, CancellationToken ct)
    {
        var experimentId = (ExperimentId)(object)ExperimentId;

        IQueryable<HypothesisBatch> query = DbContext.HypothesisBatches
            .Include(r => r.Hypotheses)
            .Where(r => r.ExperimentId == experimentId);

        query = state.SortLabel switch
        {
            "Id" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.Id) : query.OrderBy(x => x.Id),
            "Hypotheses" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.Hypotheses.Count) : query.OrderBy(x => x.Hypotheses.Count),
            "TotalTime" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.Hypotheses.Sum(h => h.TimeUsedMs)) : query.OrderBy(x => x.Hypotheses.Sum(h => h.TimeUsedMs)),
            "CreatedAt" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.CreatedAt) : query.OrderBy(x => x.CreatedAt),
            _ => query.OrderByDescending(x => x.CreatedAt)
        };

        var totalItems = await query.CountAsync(ct);
        var runs = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).ToListAsync(ct);

        var items = runs.Select(HypothesisBatchRunRowMapper.FromTrackedBatch).ToList();

        return new TableData<HypothesisBatchRunRowViewModel> { TotalItems = totalItems, Items = items };
    }

    private void OnRowClick(TableRowClickEventArgs<HypothesisBatchRunRowViewModel> args)
    {
        Navigation.NavigateTo($"/profiles/{ExperimentId}/runs/{(int)(object)args.Item!.Run.Id}");
    }

    private async Task DeleteSingle(HypothesisBatchRunRowViewModel vm)
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Confirm Delete",
            $"Delete this run and all its hypotheses?",
            yesText: "Delete", cancelText: "Cancel");

        if (confirm == true)
        {
            DbContext.HypothesisBatches.Remove(vm.Run);
            await DbContext.SaveChangesAsync();
            Snackbar.Add("Run deleted", Severity.Success);
            await _table!.ReloadServerData();
            await LoadChartData();
        }
    }

    private async Task DeleteSelected()
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Confirm Delete",
            $"Delete {_selectedItems.Count} run(s) and all their hypotheses?",
            yesText: "Delete All", cancelText: "Cancel");

        if (confirm == true)
        {
            foreach (var vm in _selectedItems)
                DbContext.HypothesisBatches.Remove(vm.Run);
            await DbContext.SaveChangesAsync();
            Snackbar.Add($"Deleted {_selectedItems.Count} run(s)", Severity.Success);
            _selectedItems.Clear();
            await _table!.ReloadServerData();
            await LoadChartData();
        }
    }
}
