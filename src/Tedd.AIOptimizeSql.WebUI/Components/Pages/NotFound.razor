@page "/not-found"
@layout MainLayout

<PageTitle>Not Found</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8 d-flex flex-column align-center">
    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Default" Class="mb-4" />
    <MudText Typo="Typo.h4" GutterBottom="true">Page Not Found</MudText>
    <MudText Typo="Typo.body1" Class="mb-4">The content you are looking for does not exist.</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/">Go Home</MudButton>
</MudContainer>
