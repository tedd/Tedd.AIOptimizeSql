@page "/ai-connections/new"
@page "/ai-connections/{Id:int}"
@implements IDisposable
@rendermode InteractiveServer
@inject IDbContextFactory<Tedd.AIOptimizeSql.Database.AIOptimizeDbContext> DbContextFactory
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@using Microsoft.EntityFrameworkCore
@using Tedd.AIOptimizeSql.Database

<PageTitle>@(_isNew ? "New" : "Edit") AI Connection</PageTitle>

<EditNavigationGuard HasUnsavedChanges="@(() => IsModified)"
                     TrySaveAsync="TryPersistAsync"
                     DiscardAsync="DiscardChangesAsync" />

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack" />
        <MudText Typo="Typo.h4">@(_isNew ? "New" : "Edit") AI Connection</MudText>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_model == null)
    {
        <MudAlert Severity="Severity.Error">AI Connection not found.</MudAlert>
    }
    else
    {
        <MudCard Elevation="3" Class="rounded-lg">
            <MudCardContent>
                <MudForm @ref="_form" @bind-IsValid="_formValid">
                    <MudTextField @bind-Value="_model.Name" Label="Name" Required="true"
                                  RequiredError="Name is required" MaxLength="512"
                                  Variant="Variant.Outlined" Class="mb-4" />

                    <MudSelect @bind-Value="_model.Provider" Label="Provider" Required="true"
                               RequiredError="Provider is required" Variant="Variant.Outlined" Class="mb-4">
                        @foreach (var provider in Enum.GetValues<AiProvider>())
                        {
                            <MudSelectItem Value="provider">@provider.ToString()</MudSelectItem>
                        }
                    </MudSelect>

                    <MudTextField @bind-Value="_model.Model" Label="Model" Required="true"
                                  RequiredError="Model is required" MaxLength="128"
                                  HelperText="e.g. gpt-4o, gpt-4.1, claude-sonnet-4-20250514"
                                  Variant="Variant.Outlined" Class="mb-4" />

                    <MudTextField @bind-Value="_model.Endpoint" Label="Endpoint" Required="true"
                                  RequiredError="Endpoint is required" MaxLength="512"
                                  HelperText="Base URL for the AI provider"
                                  Variant="Variant.Outlined" Class="mb-4" />

                    <MudTextField @bind-Value="_model.ApiKey" Label="API Key" Required="true"
                                  RequiredError="API Key is required" MaxLength="1024"
                                  InputType="InputType.Password" Variant="Variant.Outlined" Class="mb-4" />

                    @if (!_isNew)
                    {
                        <MudStack Row="true" Spacing="4">
                            <MudText Typo="Typo.caption">Created: @_model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudText>
                            <MudText Typo="Typo.caption">Modified: @_model.ModifiedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudText>
                        </MudStack>
                    }
                </MudForm>
            </MudCardContent>
            <MudCardActions Class="pa-4">
                <MudSpacer />
                <MudButton Variant="Variant.Text" OnClick="GoBack" Class="mr-2">Cancel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!_formValid)"
                           OnClick="Save" StartIcon="@Icons.Material.Filled.Save">
                    Save
                </MudButton>
            </MudCardActions>
        </MudCard>
    }
</MudContainer>

@code {
    [Parameter] public int? Id { get; set; }

    private AIConnection? _model;
    private bool _isNew;
    private bool _loading = true;
    private bool _formValid;
    private MudForm? _form;
    private readonly CancellationTokenSource _pageCts = new();
    private AIOptimizeDbContext? _db;
    private string _baselineName = "";
    private AiProvider _baselineProvider;
    private string _baselineModel = "";
    private string _baselineEndpoint = "";
    private string _baselineApiKey = "";

    private bool IsModified =>
        !_loading && _model != null &&
        (_model.Name != _baselineName ||
         _model.Provider != _baselineProvider ||
         _model.Model != _baselineModel ||
         _model.Endpoint != _baselineEndpoint ||
         _model.ApiKey != _baselineApiKey);

    private void CaptureBaseline()
    {
        if (_model == null) return;
        _baselineName = _model.Name;
        _baselineProvider = _model.Provider;
        _baselineModel = _model.Model;
        _baselineEndpoint = _model.Endpoint;
        _baselineApiKey = _model.ApiKey;
    }

    public void Dispose()
    {
        _pageCts.Cancel();
        _pageCts.Dispose();
        _db?.Dispose();
        _db = null;
    }

    protected override Task OnInitializedAsync() =>
        PageLoadCancellation.RunPageLoadAsync(async ct =>
        {
            _db = await DbContextFactory.CreateDbContextAsync(ct);
            if (Id.HasValue)
            {
                _isNew = false;
                var id = (AIConnectionId)(object)Id.Value;
                _model = await _db.AIConnections.AsTracking().FirstOrDefaultAsync(a => a.Id == id, ct);
            }
            else
            {
                _isNew = true;
                _model = new AIConnection
                {
                    Name = "",
                    Provider = AiProvider.OpenAI,
                    Model = "",
                    Endpoint = "",
                    ApiKey = ""
                };
            }
            _loading = false;
            CaptureBaseline();
        }, _pageCts.Token);

    private async Task<bool> TryPersistAsync()
    {
        if (_db is null || _model == null) return false;
        await _form!.ValidateAsync();
        if (!_formValid) return false;

        if (_isNew)
        {
            _model.CreatedAt = DateTime.UtcNow;
            _model.ModifiedAt = DateTime.UtcNow;
            _db.AIConnections.Add(_model);
        }
        else
        {
            _model.ModifiedAt = DateTime.UtcNow;
        }

        await _db.SaveChangesAsync();
        Snackbar.Add(_isNew ? "AI Connection created" : "AI Connection saved", Severity.Success);
        CaptureBaseline();
        return true;
    }

    private async Task Save()
    {
        if (!await TryPersistAsync()) return;
        Navigation.NavigateTo("/ai-connections");
    }

    private async Task DiscardChangesAsync()
    {
        if (_db is null || _model == null) return;
        if (_isNew)
        {
            _model = new AIConnection
            {
                Name = "",
                Provider = AiProvider.OpenAI,
                Model = "",
                Endpoint = "",
                ApiKey = ""
            };
        }
        else
        {
            var id = (AIConnectionId)(object)_model.Id;
            _db.Entry(_model).State = EntityState.Detached;
            _model = await _db.AIConnections.AsTracking().FirstOrDefaultAsync(a => a.Id == id, _pageCts.Token);
            if (_model == null)
            {
                Snackbar.Add("AI Connection not found.", Severity.Error);
                return;
            }
        }

        CaptureBaseline();
        await InvokeAsync(StateHasChanged);
    }

    private void GoBack() => Navigation.NavigateTo("/ai-connections");
}
