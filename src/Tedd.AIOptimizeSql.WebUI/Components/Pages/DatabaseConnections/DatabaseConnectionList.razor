@page "/database-connections"
@implements IDisposable
@rendermode InteractiveServer
@inject IDbContextFactory<Tedd.AIOptimizeSql.Database.AIOptimizeDbContext> DbContextFactory
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@using Microsoft.EntityFrameworkCore
@using Tedd.AIOptimizeSql.Database
@using Tedd.AIOptimizeSql.Database.Models

<PageTitle>Database Connections</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudText Typo="Typo.h4">Database Connections</MudText>
        <MudSpacer />
        @if (_selectedItems.Count > 0)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete"
                       OnClick="DeleteSelected" Class="mr-2">
                Delete Selected (@_selectedItems.Count)
            </MudButton>
        }
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   Href="/database-connections/new">
            New Connection
        </MudButton>
    </MudStack>

    <MudTable @ref="_table" T="DatabaseConnection" ServerData="LoadServerData" Hover="true" Elevation="3"
              Dense="true" FixedHeader="true" MultiSelection="true" @bind-SelectedItems="_selectedItems"
              OnRowClick="OnRowClick" RowClass="cursor-pointer" Class="rounded-lg">
        <HeaderContent>
            <MudTh><MudTableSortLabel SortLabel="Name" T="DatabaseConnection">Name</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="ConnectionString" T="DatabaseConnection">Connection String</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="CreatedAt" T="DatabaseConnection">Created</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="ModifiedAt" T="DatabaseConnection">Modified</MudTableSortLabel></MudTh>
            <MudTh Style="width: 80px;">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="Connection String">
                <MudText Typo="Typo.body2" Style="max-width:400px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                    @MaskConnectionString(context.ConnectionString)
                </MudText>
            </MudTd>
            <MudTd DataLabel="Created">@context.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</MudTd>
            <MudTd DataLabel="Modified">@context.ModifiedAt.ToLocalTime().ToString("yyyy-MM-dd")</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                               OnClick="@(() => DeleteSingle(context))" aria-label="Delete" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body1" Class="pa-4">No database connections found.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 20, 50, 100 }" />
        </PagerContent>
    </MudTable>
</MudContainer>

@code {
    private readonly CancellationTokenSource _pageCts = new();
    private MudTable<DatabaseConnection>? _table;
    private HashSet<DatabaseConnection> _selectedItems = new();

    public void Dispose()
    {
        _pageCts.Cancel();
        _pageCts.Dispose();
    }

    private string MaskConnectionString(string cs)
    {
        if (string.IsNullOrEmpty(cs)) return "";
        return cs.Length > 60 ? cs[..60] + "..." : cs;
    }

    private Task<TableData<DatabaseConnection>> LoadServerData(TableState state, CancellationToken ct) =>
        PageLoadCancellation.RunTableLoadAsync(t => LoadServerDataCore(state, t), _pageCts.Token, ct);

    private async Task<TableData<DatabaseConnection>> LoadServerDataCore(TableState state, CancellationToken cancellationToken)
    {
        await using var db = await DbContextFactory.CreateDbContextAsync(cancellationToken);
        IQueryable<DatabaseConnection> query = db.DatabaseConnections;

        query = state.SortLabel switch
        {
            "Name" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.Name) : query.OrderBy(x => x.Name),
            "ConnectionString" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.ConnectionString) : query.OrderBy(x => x.ConnectionString),
            "CreatedAt" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.CreatedAt) : query.OrderBy(x => x.CreatedAt),
            "ModifiedAt" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.ModifiedAt) : query.OrderBy(x => x.ModifiedAt),
            _ => query.OrderByDescending(x => x.ModifiedAt)
        };

        var totalItems = await query.CountAsync(cancellationToken);
        var items = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).ToListAsync(cancellationToken);

        return new TableData<DatabaseConnection> { TotalItems = totalItems, Items = items };
    }

    private void OnRowClick(TableRowClickEventArgs<DatabaseConnection> args)
    {
        Navigation.NavigateTo($"/database-connections/{(int)(object)args.Item!.Id}");
    }

    private async Task DeleteSingle(DatabaseConnection item)
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Confirm Delete",
            $"Delete connection \"{item.Name}\"? Any experiments using this connection will have their reference cleared.",
            yesText: "Delete", cancelText: "Cancel");

        if (confirm == true)
        {
            await using var db = await DbContextFactory.CreateDbContextAsync();
            await NullOutReferences(db, item.Id);
            var deleted = await db.DatabaseConnections.Where(c => c.Id == item.Id).ExecuteDeleteAsync();
            if (deleted == 0)
                return;
            Snackbar.Add($"Deleted \"{item.Name}\"", Severity.Success);
            await _table!.ReloadServerData();
        }
    }

    private async Task DeleteSelected()
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Confirm Delete",
            $"Delete {_selectedItems.Count} connection(s)? Experiments using these connections will have their references cleared.",
            yesText: "Delete All", cancelText: "Cancel");

        if (confirm == true)
        {
            var ids = _selectedItems.Select(i => i.Id).ToList();
            await using var db = await DbContextFactory.CreateDbContextAsync();
            await db.Experiments
                .Where(p => p.DatabaseConnectionId != null && ids.Contains(p.DatabaseConnectionId.Value))
                .ExecuteUpdateAsync(s => s
                    .SetProperty(p => p.DatabaseConnectionId, (DatabaseConnectionId?)null)
                    .SetProperty(p => p.ModifiedAt, DateTime.UtcNow));
            var deleted = await db.DatabaseConnections.Where(c => ids.Contains(c.Id)).ExecuteDeleteAsync();
            Snackbar.Add(deleted == 0 ? "Nothing deleted" : $"Deleted {deleted} connection(s)", deleted == 0 ? Severity.Info : Severity.Success);
            _selectedItems.Clear();
            await _table!.ReloadServerData();
        }
    }

    private static Task NullOutReferences(AIOptimizeDbContext db, DatabaseConnectionId id) =>
        db.Experiments
            .Where(p => p.DatabaseConnectionId == id)
            .ExecuteUpdateAsync(s => s
                .SetProperty(p => p.DatabaseConnectionId, (DatabaseConnectionId?)null)
                .SetProperty(p => p.ModifiedAt, DateTime.UtcNow));
}
