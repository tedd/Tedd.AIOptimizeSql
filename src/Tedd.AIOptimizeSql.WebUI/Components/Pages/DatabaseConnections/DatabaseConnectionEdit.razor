@page "/database-connections/new"
@page "/database-connections/{Id:int}"
@implements IDisposable
@rendermode InteractiveServer
@inject IDbContextFactory<Tedd.AIOptimizeSql.Database.AIOptimizeDbContext> DbContextFactory
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@using Microsoft.EntityFrameworkCore
@using Tedd.AIOptimizeSql.Database
@using Tedd.AIOptimizeSql.Database.Models

<PageTitle>@(_isNew ? "New" : "Edit") Database Connection</PageTitle>

<EditNavigationGuard HasUnsavedChanges="@(() => IsModified)"
                     TrySaveAsync="TryPersistAsync"
                     DiscardAsync="DiscardChangesAsync" />

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack" />
        <MudText Typo="Typo.h4">@(_isNew ? "New" : "Edit") Database Connection</MudText>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_model == null)
    {
        <MudAlert Severity="Severity.Error">Connection not found.</MudAlert>
    }
    else
    {
        <MudCard Elevation="3" Class="rounded-lg">
            <MudCardContent>
                <MudForm @ref="_form" @bind-IsValid="_formValid">
                    <MudTextField @bind-Value="_model.Name" Label="Name" Required="true"
                                  RequiredError="Name is required" MaxLength="512"
                                  Variant="Variant.Outlined" Class="mb-4" />
                    <MudTextField @bind-Value="_model.ConnectionString" Label="Connection String" Required="true"
                                  RequiredError="Connection string is required" MaxLength="4000"
                                  Lines="3" Variant="Variant.Outlined" Class="mb-4" />

                    @if (!_isNew)
                    {
                        <MudStack Row="true" Spacing="4">
                            <MudText Typo="Typo.caption">Created: @_model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudText>
                            <MudText Typo="Typo.caption">Modified: @_model.ModifiedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudText>
                        </MudStack>
                    }
                </MudForm>
            </MudCardContent>
            <MudCardActions Class="pa-4">
                <MudSpacer />
                <MudButton Variant="Variant.Text" OnClick="GoBack" Class="mr-2">Cancel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!_formValid)"
                           OnClick="Save" StartIcon="@Icons.Material.Filled.Save">
                    Save
                </MudButton>
            </MudCardActions>
        </MudCard>
    }
</MudContainer>

@code {
    [Parameter] public int? Id { get; set; }

    private DatabaseConnection? _model;
    private bool _isNew;
    private bool _loading = true;
    private bool _formValid;
    private MudForm? _form;
    private readonly CancellationTokenSource _pageCts = new();
    private AIOptimizeDbContext? _db;
    private string _baselineName = "";
    private string _baselineConnectionString = "";

    private bool IsModified =>
        !_loading && _model != null &&
        (_model.Name != _baselineName || _model.ConnectionString != _baselineConnectionString);

    private void CaptureBaseline()
    {
        if (_model == null) return;
        _baselineName = _model.Name;
        _baselineConnectionString = _model.ConnectionString;
    }

    public void Dispose()
    {
        _pageCts.Cancel();
        _pageCts.Dispose();
        _db?.Dispose();
        _db = null;
    }

    protected override Task OnInitializedAsync() =>
        PageLoadCancellation.RunPageLoadAsync(async ct =>
        {
            _db = await DbContextFactory.CreateDbContextAsync(ct);
            if (Id.HasValue)
            {
                _isNew = false;
                var id = (DatabaseConnectionId)(object)Id.Value;
                _model = await _db.DatabaseConnections.AsNoTracking().FirstOrDefaultAsync(c => c.Id == id, ct);
            }
            else
            {
                _isNew = true;
                _model = new DatabaseConnection { Name = "", ConnectionString = "" };
            }
            _loading = false;
            CaptureBaseline();
        }, _pageCts.Token);

    private async Task<bool> TryPersistAsync()
    {
        if (_db is null || _model == null) return false;
        await _form!.ValidateAsync();
        if (!_formValid) return false;

        if (_isNew)
        {
            _model.CreatedAt = DateTime.UtcNow;
            _model.ModifiedAt = DateTime.UtcNow;
            _db.DatabaseConnections.Add(_model);
            await _db.SaveChangesAsync();
            _db.ChangeTracker.Clear();
        }
        else
        {
            var id = (DatabaseConnectionId)(object)_model.Id;
            var now = DateTime.UtcNow;
            var n = await _db.DatabaseConnections.Where(c => c.Id == id).ExecuteUpdateAsync(s => s
                .SetProperty(c => c.Name, _model.Name)
                .SetProperty(c => c.ConnectionString, _model.ConnectionString)
                .SetProperty(c => c.ModifiedAt, now));
            if (n != 1)
            {
                Snackbar.Add("Connection not found or was deleted.", Severity.Error);
                return false;
            }

            _model.ModifiedAt = now;
        }
        Snackbar.Add(_isNew ? "Connection created" : "Connection saved", Severity.Success);
        CaptureBaseline();
        return true;
    }

    private async Task Save()
    {
        if (!await TryPersistAsync()) return;
        Navigation.NavigateTo("/database-connections");
    }

    private async Task DiscardChangesAsync()
    {
        if (_db is null || _model == null) return;
        if (_isNew)
        {
            _model = new DatabaseConnection { Name = "", ConnectionString = "" };
        }
        else
        {
            var id = (DatabaseConnectionId)(object)_model.Id;
            _model = await _db.DatabaseConnections.AsNoTracking().FirstOrDefaultAsync(c => c.Id == id, _pageCts.Token);
            if (_model == null)
            {
                Snackbar.Add("Connection not found.", Severity.Error);
                return;
            }
        }

        CaptureBaseline();
        await InvokeAsync(StateHasChanged);
    }

    private void GoBack() => Navigation.NavigateTo("/database-connections");
}
