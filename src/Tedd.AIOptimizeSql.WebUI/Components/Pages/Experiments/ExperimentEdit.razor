@page "/experiments/new"
@page "/experiments/{Id:int}/edit"
@implements IDisposable
@rendermode InteractiveServer
@inject Tedd.AIOptimizeSql.Database.AIOptimizeDbContext DbContext
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@using Microsoft.EntityFrameworkCore

<PageTitle>@(_isNew ? "New" : "Edit") Experiment</PageTitle>

<EditNavigationGuard HasUnsavedChanges="@(() => IsModified)"
                     TrySaveAsync="TryPersistAsync"
                     DiscardAsync="DiscardAsync" />

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack" />
        <MudText Typo="Typo.h4">@(_isNew ? "New" : "Edit") Experiment</MudText>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_model == null)
    {
        <MudAlert Severity="Severity.Error">Experiment not found.</MudAlert>
    }
    else
    {
        <MudCard Elevation="3" Class="rounded-lg">
            <MudCardContent>
                <MudForm @ref="_form" @bind-IsValid="_formValid">
                    <MudTabs @bind-ActivePanelIndex="_activeTabIndex" Rounded="true" Border="true" Class="mb-2">
                        <MudTabPanel Text="Details">
                            <MudStack Spacing="0" Class="pt-4">
                                <MudTextField @bind-Value="_model.Name" Label="Name" Required="true"
                                              RequiredError="Name is required" MaxLength="1024"
                                              Variant="Variant.Outlined" Class="mb-4" />

                                <MudTextField @bind-Value="_model.Description" Label="Description"
                                              Lines="2" Variant="Variant.Outlined" Class="mb-4"
                                              HelperText="Human-readable description (not used by AI)" />

                                <MudSelect T="DatabaseConnectionId?" @bind-Value="_selectedDbConnId" Label="Database Connection"
                                           Variant="Variant.Outlined" Class="mb-4" Clearable="true"
                                           HelperText="Target database for optimization">
                                    @foreach (var conn in _dbConnections)
                                    {
                                        <MudSelectItem Value="@((DatabaseConnectionId?)conn.Id)">@conn.Name</MudSelectItem>
                                    }
                                </MudSelect>

                                <MudSelect T="AIConnectionId?" @bind-Value="_selectedAiConnId" Label="AI Connection"
                                           Variant="Variant.Outlined" Class="mb-4" Clearable="true"
                                           HelperText="AI provider for optimization">
                                    @foreach (var conn in _aiConnections)
                                    {
                                        <MudSelectItem Value="@((AIConnectionId?)conn.Id)">@conn.Name (@conn.Provider / @conn.Model)</MudSelectItem>
                                    }
                                </MudSelect>

                                <MudTextField @bind-Value="_model.Instructions" Label="AI Instructions"
                                              Lines="3" Variant="Variant.Outlined" Class="mb-4"
                                              HelperText="Instructions for the AI optimizer" />

                                @if (!_isNew)
                                {
                                    <MudStack Row="true" Spacing="4" Class="mb-4">
                                        <MudText Typo="Typo.caption">Created: @_model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudText>
                                        <MudText Typo="Typo.caption">Modified: @_model.ModifiedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudText>
                                    </MudStack>
                                }

                                @TabActions(showResearchIterationsLink: true)
                            </MudStack>
                        </MudTabPanel>

                        <MudTabPanel Text="SQL">
                            <MudStack Spacing="0" Class="pt-4">
                                <MudText Typo="Typo.subtitle2" Class="mb-2">Hypothesis SQL</MudText>
                                <MudTextField @bind-Value="_model.HypothesisPreRunSql" Label="Hypothesis Pre-Run SQL"
                                              Lines="3" Variant="Variant.Outlined" Class="mb-4"
                                              HelperText="Executed before each hypothesis" />

                                <MudTextField @bind-Value="_model.HypothesisPostRunSql" Label="Hypothesis Post-Run SQL"
                                              Lines="3" Variant="Variant.Outlined" Class="mb-4"
                                              HelperText="Executed after each hypothesis" />

                                <MudText Typo="Typo.subtitle2" Class="mb-2 mt-2">Experiment SQL</MudText>
                                <MudTextField @bind-Value="_model.ExperimentPreRunSql" Label="Pre-Run SQL"
                                              Lines="3" Variant="Variant.Outlined" Class="mb-4"
                                              HelperText="Executed before optimization starts" />

                                <MudTextField @bind-Value="_model.ExperimentPostRunSql" Label="Post-Run SQL"
                                              Lines="3" Variant="Variant.Outlined" Class="mb-4"
                                              HelperText="Executed after each run" />

                                <MudTextField @bind-Value="_model.BenchmarkSql" Label="Benchmark SQL"
                                              Lines="3" Variant="Variant.Outlined" Class="mb-4"
                                              HelperText="SQL used to benchmark performance" />

                                @TabActions(showResearchIterationsLink: false)
                            </MudStack>
                        </MudTabPanel>
                    </MudTabs>
                </MudForm>
            </MudCardContent>
        </MudCard>
    }
</MudContainer>

@code {
    [Parameter] public int? Id { get; set; }

    private Experiment? _model;
    private bool _isNew;
    private bool _loading = true;
    private bool _formValid;
    private int _activeTabIndex;
    private MudForm? _form;
    private List<DatabaseConnection> _dbConnections = new();
    private List<AIConnection> _aiConnections = new();
    private DatabaseConnectionId? _selectedDbConnId;
    private AIConnectionId? _selectedAiConnId;
    private readonly CancellationTokenSource _pageCts = new();

    private string _baselineName = "";
    private string _baselineDescription = "";
    private string _baselineInstructions = "";
    private string _baselineHypothesisPreRunSql = "";
    private string _baselineHypothesisPostRunSql = "";
    private string _baselineExperimentPreRunSql = "";
    private string _baselineExperimentPostRunSql = "";
    private string _baselineBenchmarkSql = "";
    private DatabaseConnectionId? _baselineDbConnId;
    private AIConnectionId? _baselineAiConnId;

    private bool IsModified =>
        !_loading && _model != null &&
        (_model.Name != _baselineName ||
         (_model.Description ?? "") != _baselineDescription ||
         (_model.Instructions ?? "") != _baselineInstructions ||
         (_model.HypothesisPreRunSql ?? "") != _baselineHypothesisPreRunSql ||
         (_model.HypothesisPostRunSql ?? "") != _baselineHypothesisPostRunSql ||
         (_model.ExperimentPreRunSql ?? "") != _baselineExperimentPreRunSql ||
         (_model.ExperimentPostRunSql ?? "") != _baselineExperimentPostRunSql ||
         (_model.BenchmarkSql ?? "") != _baselineBenchmarkSql ||
         _selectedDbConnId != _baselineDbConnId ||
         _selectedAiConnId != _baselineAiConnId);

    private void CaptureBaseline()
    {
        if (_model == null) return;
        _baselineName = _model.Name;
        _baselineDescription = _model.Description ?? "";
        _baselineInstructions = _model.Instructions ?? "";
        _baselineHypothesisPreRunSql = _model.HypothesisPreRunSql ?? "";
        _baselineHypothesisPostRunSql = _model.HypothesisPostRunSql ?? "";
        _baselineExperimentPreRunSql = _model.ExperimentPreRunSql ?? "";
        _baselineExperimentPostRunSql = _model.ExperimentPostRunSql ?? "";
        _baselineBenchmarkSql = _model.BenchmarkSql ?? "";
        _baselineDbConnId = _selectedDbConnId;
        _baselineAiConnId = _selectedAiConnId;
    }

    private RenderFragment TabActions(bool showResearchIterationsLink) => __builder =>
    {
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mt-4 flex-wrap" Style="gap: 8px;">
            @if (showResearchIterationsLink && !_isNew)
            {
                <MudButton Variant="Variant.Text" Color="Color.Info"
                           Href="@($"/experiments/{Id}/research-iterations")" StartIcon="@Icons.Material.Filled.PlayArrow">
                    View research iterations
                </MudButton>
            }
            <MudSpacer />
            <MudButton Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Filled.NavigateBefore"
                       Disabled="@(_activeTabIndex == 0)"
                       OnClick="@(() => _activeTabIndex = 0)">
                Previous
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       EndIcon="@Icons.Material.Filled.NavigateNext"
                       Disabled="@(_activeTabIndex == 1)"
                       OnClick="@(() => _activeTabIndex = 1)">
                Next
            </MudButton>
            <MudButton Variant="Variant.Text" OnClick="DiscardAsync" Disabled="@_discardBusy">
                Discard
            </MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!_formValid)"
                       OnClick="Save" StartIcon="@Icons.Material.Filled.Save">
                Save
            </MudButton>
        </MudStack>
    };

    private bool _discardBusy;

    public void Dispose()
    {
        _pageCts.Cancel();
        _pageCts.Dispose();
    }

    protected override Task OnInitializedAsync() =>
        PageLoadCancellation.RunPageLoadAsync(async ct =>
        {
            _dbConnections = await DbContext.DatabaseConnections.OrderBy(c => c.Name).ToListAsync(ct);
            _aiConnections = await DbContext.AIConnections.OrderBy(c => c.Name).ToListAsync(ct);

            if (Id.HasValue)
            {
                _isNew = false;
                var id = (ExperimentId)(object)Id.Value;
                _model = await DbContext.Experiments
                    .Include(p => p.DatabaseConnection)
                    .Include(p => p.AIConnection)
                    .FirstOrDefaultAsync(p => p.Id == id, ct);
                if (_model != null)
                {
                    _selectedDbConnId = _model.DatabaseConnectionId;
                    _selectedAiConnId = _model.AIConnectionId;
                }
            }
            else
            {
                _isNew = true;
                _model = new Experiment { Name = "" };
            }
            _loading = false;
            CaptureBaseline();
        }, _pageCts.Token);

    private async Task DiscardAsync()
    {
        if (_model == null || _discardBusy) return;
        _discardBusy = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            if (_isNew)
            {
                _model = new Experiment { Name = "" };
                _selectedDbConnId = null;
                _selectedAiConnId = null;
            }
            else
            {
                var experimentId = _model.Id;
                DbContext.Entry(_model).State = EntityState.Detached;
                _model = await DbContext.Experiments
                    .Include(p => p.DatabaseConnection)
                    .Include(p => p.AIConnection)
                    .FirstOrDefaultAsync(p => p.Id == experimentId, _pageCts.Token);
                if (_model == null)
                {
                    Snackbar.Add("Experiment not found.", Severity.Error);
                    return;
                }
                _selectedDbConnId = _model.DatabaseConnectionId;
                _selectedAiConnId = _model.AIConnectionId;
            }
            Snackbar.Add("Changes discarded.", Severity.Info);
            CaptureBaseline();
        }
        finally
        {
            _discardBusy = false;
        }
    }

    private async Task<bool> TryPersistAsync()
    {
        if (_model == null) return false;
        await _form!.ValidateAsync();
        if (!_formValid) return false;

        _model.DatabaseConnectionId = _selectedDbConnId;
        _model.AIConnectionId = _selectedAiConnId;

        if (_isNew)
        {
            _model.CreatedAt = DateTime.UtcNow;
            _model.ModifiedAt = DateTime.UtcNow;
            DbContext.Experiments.Add(_model);
        }
        else
        {
            _model.ModifiedAt = DateTime.UtcNow;
        }

        await DbContext.SaveChangesAsync();
        Snackbar.Add(_isNew ? "Experiment created" : "Experiment saved", Severity.Success);
        CaptureBaseline();
        return true;
    }

    private async Task Save()
    {
        if (!await TryPersistAsync()) return;
        Navigation.NavigateTo("/experiments");
    }

    private void GoBack() => Navigation.NavigateTo("/experiments");
}
