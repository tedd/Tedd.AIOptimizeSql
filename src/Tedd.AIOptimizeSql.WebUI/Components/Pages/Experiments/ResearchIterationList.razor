@page "/experiments/{ExperimentId:int}/research-iterations"
@implements IDisposable
@rendermode InteractiveServer
@inject IDbContextFactory<Tedd.AIOptimizeSql.Database.AIOptimizeDbContext> DbContextFactory
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@using Microsoft.EntityFrameworkCore
@using Tedd.AIOptimizeSql.Database
@using Tedd.AIOptimizeSql.Database.Models
@using Tedd.AIOptimizeSql.WebUI.Mappers
@using Tedd.AIOptimizeSql.WebUI.ViewModels

<PageTitle>Research iterations</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                       OnClick="@(() => Navigation.NavigateTo("/experiments"))" />
        <MudText Typo="Typo.h4">
            Research iterations for: @(_profile?.Name ?? "...")
        </MudText>
        <MudSpacer />
        @if (_selectedItems.Count > 0)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete"
                       OnClick="DeleteSelected" Class="mr-2">
                Delete Selected (@_selectedItems.Count)
            </MudButton>
        }
        <MudButton Variant="Variant.Text" Color="Color.Primary"
                   Href="@($"/experiments/{ExperimentId}/edit")" StartIcon="@Icons.Material.Filled.Edit" Class="mr-2">
            Edit Experiment
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   Href="@($"/experiments/{ExperimentId}/research-iterations/new")">
            New research iteration
        </MudButton>
    </MudStack>

    @if (_runChartSeries.Count > 0)
    {
        <MudCard Elevation="3" Class="rounded-lg mb-4">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Hypothesis Improvement %</MudText>
                    <MudText Typo="Typo.caption">Positive = improvement, Negative = regression</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudChart T="double" ChartType="ChartType.Bar" ChartSeries="@_runChartSeries"
                          x-axis-labels="@_chartLabels" Width="100%" Height="300px" />
            </MudCardContent>
        </MudCard>
    }

    <MudTable @ref="_table" T="ResearchIterationRunRowViewModel" ServerData="LoadServerData" Hover="true" Elevation="3"
              Dense="true" FixedHeader="true" MultiSelection="true" @bind-SelectedItems="_selectedItems"
              OnRowClick="OnRowClick" RowClass="cursor-pointer" Class="rounded-lg">
        <HeaderContent>
            <MudTh><MudTableSortLabel SortLabel="Id" T="ResearchIterationRunRowViewModel">Iteration #</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="Hypotheses" T="ResearchIterationRunRowViewModel">Hypotheses</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="TotalTime" T="ResearchIterationRunRowViewModel">Total Time</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="State" T="ResearchIterationRunRowViewModel">State</MudTableSortLabel></MudTh>
            <MudTh>Started</MudTh>
            <MudTh>Ended</MudTh>
            <MudTh>AI Provider</MudTh>
            <MudTh>Model</MudTh>
            <MudTh>Last message</MudTh>
            <MudTh>Hints</MudTh>
            <MudTh><MudTableSortLabel SortLabel="CreatedAt" T="ResearchIterationRunRowViewModel">Created</MudTableSortLabel></MudTh>
            <MudTh Style="width: 120px;">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Iteration #">@((int)(object)context.Iteration.Id)</MudTd>
            <MudTd DataLabel="Hypotheses">
                <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.HypothesisCount</MudChip>
            </MudTd>
            <MudTd DataLabel="Total Time">@FormatTime(context.TotalTimeMs)</MudTd>
            <MudTd DataLabel="State">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.Iteration.State.ToString()</MudChip>
            </MudTd>
            <MudTd DataLabel="Started">@FormatNullableLocal(context.Iteration.StartedAt)</MudTd>
            <MudTd DataLabel="Ended">@FormatNullableLocal(context.Iteration.EndedAt)</MudTd>
            <MudTd DataLabel="AI Provider">@(context.Iteration.AiProviderUsed?.ToString() ?? "—")</MudTd>
            <MudTd DataLabel="Model">@(context.Iteration.AiModelUsed ?? "—")</MudTd>
            <MudTd DataLabel="Last message">
                <MudText Typo="Typo.body2" Style="max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                    @(context.Iteration.LastMessage ?? "—")
                </MudText>
            </MudTd>
            <MudTd DataLabel="Hints">
                <MudText Typo="Typo.body2" Style="max-width:300px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                    @(context.Iteration.Hints ?? "--")
                </MudText>
            </MudTd>
            <MudTd DataLabel="Created">@context.Iteration.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                               Href="@($"/experiments/{ExperimentId}/research-iterations/{(int)(object)context.Iteration.Id}/edit")"
                               aria-label="Edit iteration" />
                <MudIconButton Icon="@Icons.Material.Filled.List" Color="Color.Info" Size="Size.Small"
                               Href="@($"/experiments/{ExperimentId}/research-iterations/{(int)(object)context.Iteration.Id}")"
                               aria-label="Hypotheses" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                               OnClick="@(() => DeleteSingle(context))" aria-label="Delete" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body1" Class="pa-4">No research iterations found.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 20, 50, 100 }" />
        </PagerContent>
    </MudTable>
</MudContainer>

@code {
    [Parameter] public int ExperimentId { get; set; }

    private readonly CancellationTokenSource _pageCts = new();
    private Experiment? _profile;
    private MudTable<ResearchIterationRunRowViewModel>? _table;
    private HashSet<ResearchIterationRunRowViewModel> _selectedItems = new();
    private string[] _chartLabels = Array.Empty<string>();
    private List<ChartSeries<double>> _runChartSeries = new();

    public void Dispose()
    {
        _pageCts.Cancel();
        _pageCts.Dispose();
    }

    protected override Task OnInitializedAsync() =>
        PageLoadCancellation.RunPageLoadAsync(async ct =>
        {
            await using var db = await DbContextFactory.CreateDbContextAsync(ct);
            var experimentId = (ExperimentId)(object)ExperimentId;
            _profile = await db.Experiments.AsNoTracking().FirstOrDefaultAsync(e => e.Id == experimentId, ct);
            await LoadChartData(db, ct);
        }, _pageCts.Token);

    private async Task LoadChartData(AIOptimizeDbContext db, CancellationToken cancellationToken = default)
    {
        var experimentId = (ExperimentId)(object)ExperimentId;
        var hypotheses = await db.Hypotheses
            .Where(h => h.ResearchIteration!.ExperimentId == experimentId)
            .OrderBy(h => h.CreatedAt)
            .Select(h => new { h.ImpovementPercentage, h.CreatedAt })
            .Take(50)
            .ToListAsync(cancellationToken);

        var data = hypotheses.Select(h => (double)h.ImpovementPercentage).ToList();
        _chartLabels = hypotheses.Select((h, i) => $"H{i + 1}").ToArray();
        _runChartSeries = data.Count == 0
            ? new List<ChartSeries<double>>()
            : new List<ChartSeries<double>> { new() { Name = "Improvement %", Data = data } };
    }

    private string FormatTime(long ms)
    {
        if (ms < 1000) return $"{ms}ms";
        if (ms < 60000) return $"{ms / 1000.0:F1}s";

        return $"{ms / 60000.0:F1}m";
    }

    private static string FormatNullableLocal(DateTime? utc) =>
        utc.HasValue ? utc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "—";

    private Task<TableData<ResearchIterationRunRowViewModel>> LoadServerData(TableState state, CancellationToken ct) =>
        PageLoadCancellation.RunTableLoadAsync(t => LoadServerDataCore(state, t), _pageCts.Token, ct);

    private async Task<TableData<ResearchIterationRunRowViewModel>> LoadServerDataCore(TableState state, CancellationToken cancellationToken)
    {
        await using var db = await DbContextFactory.CreateDbContextAsync(cancellationToken);
        var experimentId = (ExperimentId)(object)ExperimentId;

        IQueryable<ResearchIteration> query = db.ResearchIterations
            .Include(r => r.Hypotheses)
            .Where(r => r.ExperimentId == experimentId);

        query = state.SortLabel switch
        {
            "Id" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.Id) : query.OrderBy(x => x.Id),
            "Hypotheses" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.Hypotheses.Count) : query.OrderBy(x => x.Hypotheses.Count),
            "TotalTime" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.Hypotheses.Sum(h => h.TimeUsedMs)) : query.OrderBy(x => x.Hypotheses.Sum(h => h.TimeUsedMs)),
            "State" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.State) : query.OrderBy(x => x.State),
            "CreatedAt" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.CreatedAt) : query.OrderBy(x => x.CreatedAt),
            _ => query.OrderByDescending(x => x.CreatedAt)
        };

        var totalItems = await query.CountAsync(cancellationToken);
        var runs = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).ToListAsync(cancellationToken);

        var items = runs.Select(ResearchIterationRunRowMapper.FromTrackedIteration).ToList();

        return new TableData<ResearchIterationRunRowViewModel> { TotalItems = totalItems, Items = items };
    }

    private void OnRowClick(TableRowClickEventArgs<ResearchIterationRunRowViewModel> args)
    {
        Navigation.NavigateTo($"/experiments/{ExperimentId}/research-iterations/{(int)(object)args.Item!.Iteration.Id}/edit");
    }

    private async Task DeleteSingle(ResearchIterationRunRowViewModel vm)
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Confirm Delete",
            $"Delete this research iteration and all its hypotheses?",
            yesText: "Delete", cancelText: "Cancel");

        if (confirm == true)
        {
            await using var db = await DbContextFactory.CreateDbContextAsync();
            var deleted = await db.ResearchIterations.Where(r => r.Id == vm.Iteration.Id).ExecuteDeleteAsync();
            if (deleted == 0)
                return;
            Snackbar.Add("Research iteration deleted", Severity.Success);
            await _table!.ReloadServerData();
            await RefreshChartAsync();
        }
    }

    private async Task DeleteSelected()
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Confirm Delete",
            $"Delete {_selectedItems.Count} research iteration(s) and all their hypotheses?",
            yesText: "Delete All", cancelText: "Cancel");

        if (confirm == true)
        {
            var ids = _selectedItems.Select(vm => vm.Iteration.Id).ToList();
            await using var db = await DbContextFactory.CreateDbContextAsync();
            var deleted = await db.ResearchIterations.Where(r => ids.Contains(r.Id)).ExecuteDeleteAsync();
            Snackbar.Add(deleted == 0 ? "Nothing deleted" : $"Deleted {deleted} research iteration(s)", deleted == 0 ? Severity.Info : Severity.Success);
            _selectedItems.Clear();
            await _table!.ReloadServerData();
            await RefreshChartAsync();
        }
    }

    private async Task RefreshChartAsync(CancellationToken cancellationToken = default)
    {
        await using var db = await DbContextFactory.CreateDbContextAsync(cancellationToken);
        await LoadChartData(db, cancellationToken);
    }
}
