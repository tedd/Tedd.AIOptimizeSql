@page "/experiments/{ExperimentId:int}/hypothesis-batches"
@implements IDisposable
@rendermode InteractiveServer
@inject Tedd.AIOptimizeSql.Database.AIOptimizeDbContext DbContext
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@using Microsoft.EntityFrameworkCore

<PageTitle>Hypothesis Batches</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                       OnClick="@(() => Navigation.NavigateTo("/experiments"))" />
        <MudText Typo="Typo.h4">
            Hypothesis Batches for: @(_profile?.Name ?? "...")
        </MudText>
        <MudSpacer />
        @if (_selectedItems.Count > 0)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete"
                       OnClick="DeleteSelected" Class="mr-2">
                Delete Selected (@_selectedItems.Count)
            </MudButton>
        }
        <MudButton Variant="Variant.Text" Color="Color.Primary"
                   Href="@($"/experiments/{ExperimentId}/edit")" StartIcon="@Icons.Material.Filled.Edit" Class="mr-2">
            Edit Experiment
        </MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   Href="@($"/experiments/{ExperimentId}/hypothesis-batches/new")">
            New hypothesis batch
        </MudButton>
    </MudStack>

    @if (_runChartSeries.Count > 0)
    {
        <MudCard Elevation="3" Class="rounded-lg mb-4">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">Hypothesis Improvement %</MudText>
                    <MudText Typo="Typo.caption">Positive = improvement, Negative = regression</MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudChart T="double" ChartType="ChartType.Bar" ChartSeries="@_runChartSeries"
                          x-axis-labels="@_chartLabels" Width="100%" Height="300px" />
            </MudCardContent>
        </MudCard>
    }

    <MudTable @ref="_table" T="RunViewModel" ServerData="LoadServerData" Hover="true" Elevation="3"
              Dense="true" FixedHeader="true" MultiSelection="true" @bind-SelectedItems="_selectedItems"
              OnRowClick="OnRowClick" RowClass="cursor-pointer" Class="rounded-lg">
        <HeaderContent>
            <MudTh><MudTableSortLabel SortLabel="Id" T="RunViewModel">Batch #</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="Hypotheses" T="RunViewModel">Hypotheses</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="TotalTime" T="RunViewModel">Total Time</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="State" T="RunViewModel">State</MudTableSortLabel></MudTh>
            <MudTh>Started</MudTh>
            <MudTh>Ended</MudTh>
            <MudTh>AI Provider</MudTh>
            <MudTh>Model</MudTh>
            <MudTh>Last message</MudTh>
            <MudTh>Hints</MudTh>
            <MudTh><MudTableSortLabel SortLabel="CreatedAt" T="RunViewModel">Created</MudTableSortLabel></MudTh>
            <MudTh Style="width: 120px;">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Batch #">@((int)(object)context.Run.Id)</MudTd>
            <MudTd DataLabel="Hypotheses">
                <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.HypothesisCount</MudChip>
            </MudTd>
            <MudTd DataLabel="Total Time">@FormatTime(context.TotalTimeMs)</MudTd>
            <MudTd DataLabel="State">
                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@context.Run.State.ToString()</MudChip>
            </MudTd>
            <MudTd DataLabel="Started">@FormatNullableLocal(context.Run.StartedAt)</MudTd>
            <MudTd DataLabel="Ended">@FormatNullableLocal(context.Run.EndedAt)</MudTd>
            <MudTd DataLabel="AI Provider">@(context.Run.AiProviderUsed?.ToString() ?? "—")</MudTd>
            <MudTd DataLabel="Model">@(context.Run.AiModelUsed ?? "—")</MudTd>
            <MudTd DataLabel="Last message">
                <MudText Typo="Typo.body2" Style="max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                    @(context.Run.LastMessage ?? "—")
                </MudText>
            </MudTd>
            <MudTd DataLabel="Hints">
                <MudText Typo="Typo.body2" Style="max-width:300px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">
                    @(context.Run.Hints ?? "--")
                </MudText>
            </MudTd>
            <MudTd DataLabel="Created">@context.Run.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                               Href="@($"/experiments/{ExperimentId}/hypothesis-batches/{(int)(object)context.Run.Id}/edit")"
                               aria-label="Edit batch" />
                <MudIconButton Icon="@Icons.Material.Filled.List" Color="Color.Info" Size="Size.Small"
                               Href="@($"/experiments/{ExperimentId}/hypothesis-batches/{(int)(object)context.Run.Id}")"
                               aria-label="Hypotheses" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                               OnClick="@(() => DeleteSingle(context))" aria-label="Delete" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body1" Class="pa-4">No hypothesis batches found.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 20, 50, 100 }" />
        </PagerContent>
    </MudTable>
</MudContainer>

@code {
    [Parameter] public int ExperimentId { get; set; }

    private readonly CancellationTokenSource _pageCts = new();
    private Experiment? _profile;
    private MudTable<RunViewModel>? _table;
    private HashSet<RunViewModel> _selectedItems = new();
    private string[] _chartLabels = Array.Empty<string>();
    private List<ChartSeries<double>> _runChartSeries = new();

    private class RunViewModel
    {
        public required HypothesisBatch Run { get; init; }
        public int HypothesisCount { get; init; }
        public long TotalTimeMs { get; init; }
    }

    public void Dispose()
    {
        _pageCts.Cancel();
        _pageCts.Dispose();
    }

    protected override Task OnInitializedAsync() =>
        PageLoadCancellation.RunPageLoadAsync(async ct =>
        {
            var experimentId = (ExperimentId)(object)ExperimentId;
            _profile = await DbContext.Experiments.FindAsync(new object[] { experimentId }, ct);
            await LoadChartData(ct);
        }, _pageCts.Token);

    private async Task LoadChartData(CancellationToken cancellationToken = default)
    {
        var experimentId = (ExperimentId)(object)ExperimentId;
        var hypotheses = await DbContext.Hypotheses
            .Where(h => h.HypothesisBatch!.ExperimentId == experimentId)
            .OrderBy(h => h.CreatedAt)
            .Select(h => new { h.ImpovementPercentage, h.CreatedAt })
            .Take(50)
            .ToListAsync(cancellationToken);

        var data = hypotheses.Select(h => (double)h.ImpovementPercentage).ToList();
        _chartLabels = hypotheses.Select((h, i) => $"H{i + 1}").ToArray();
        _runChartSeries = data.Count == 0
            ? new List<ChartSeries<double>>()
            : new List<ChartSeries<double>> { new() { Name = "Improvement %", Data = data } };
    }

    private string FormatTime(long ms)
    {
        if (ms < 1000) return $"{ms}ms";
        if (ms < 60000) return $"{ms / 1000.0:F1}s";
        return $"{ms / 60000.0:F1}m";
    }

    private static string FormatNullableLocal(DateTime? utc) =>
        utc.HasValue ? utc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "—";

    private Task<TableData<RunViewModel>> LoadServerData(TableState state, CancellationToken ct) =>
        PageLoadCancellation.RunTableLoadAsync(t => LoadServerDataCore(state, t), _pageCts.Token, ct);

    private async Task<TableData<RunViewModel>> LoadServerDataCore(TableState state, CancellationToken cancellationToken)
    {
        var experimentId = (ExperimentId)(object)ExperimentId;

        IQueryable<HypothesisBatch> query = DbContext.HypothesisBatches
            .Include(r => r.Hypotheses)
            .Where(r => r.ExperimentId == experimentId);

        query = state.SortLabel switch
        {
            "Id" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.Id) : query.OrderBy(x => x.Id),
            "Hypotheses" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.Hypotheses.Count) : query.OrderBy(x => x.Hypotheses.Count),
            "TotalTime" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.Hypotheses.Sum(h => h.TimeUsedMs)) : query.OrderBy(x => x.Hypotheses.Sum(h => h.TimeUsedMs)),
            "State" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.State) : query.OrderBy(x => x.State),
            "CreatedAt" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.CreatedAt) : query.OrderBy(x => x.CreatedAt),
            _ => query.OrderByDescending(x => x.CreatedAt)
        };

        var totalItems = await query.CountAsync(cancellationToken);
        var runs = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).ToListAsync(cancellationToken);

        var items = runs.Select(r => new RunViewModel
        {
            Run = r,
            HypothesisCount = r.Hypotheses.Count,
            TotalTimeMs = r.Hypotheses.Sum(h => h.TimeUsedMs)
        }).ToList();

        return new TableData<RunViewModel> { TotalItems = totalItems, Items = items };
    }

    private void OnRowClick(TableRowClickEventArgs<RunViewModel> args)
    {
        Navigation.NavigateTo($"/experiments/{ExperimentId}/hypothesis-batches/{(int)(object)args.Item!.Run.Id}/edit");
    }

    private async Task DeleteSingle(RunViewModel vm)
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Confirm Delete",
            $"Delete this hypothesis batch and all its hypotheses?",
            yesText: "Delete", cancelText: "Cancel");

        if (confirm == true)
        {
            DbContext.HypothesisBatches.Remove(vm.Run);
            await DbContext.SaveChangesAsync();
            Snackbar.Add("Hypothesis batch deleted", Severity.Success);
            await _table!.ReloadServerData();
            await LoadChartData();
        }
    }

    private async Task DeleteSelected()
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Confirm Delete",
            $"Delete {_selectedItems.Count} hypothesis batch(es) and all their hypotheses?",
            yesText: "Delete All", cancelText: "Cancel");

        if (confirm == true)
        {
            foreach (var vm in _selectedItems)
                DbContext.HypothesisBatches.Remove(vm.Run);
            await DbContext.SaveChangesAsync();
            Snackbar.Add($"Deleted {_selectedItems.Count} hypothesis batch(es)", Severity.Success);
            _selectedItems.Clear();
            await _table!.ReloadServerData();
            await LoadChartData();
        }
    }
}
