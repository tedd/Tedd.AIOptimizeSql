@page "/experiments"
@implements IDisposable
@rendermode InteractiveServer
@inject IDbContextFactory<Tedd.AIOptimizeSql.Database.AIOptimizeDbContext> DbContextFactory
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@using Microsoft.EntityFrameworkCore

<PageTitle>Experiments</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudText Typo="Typo.h4">Experiments</MudText>
        <MudSpacer />
        @if (_selectedItems.Count > 0)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Delete"
                       OnClick="DeleteSelected" Class="mr-2">
                Delete Selected (@_selectedItems.Count)
            </MudButton>
        }
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   Href="/experiments/new">
            New Experiment
        </MudButton>
    </MudStack>

    <MudTable @ref="_table" T="Experiment" ServerData="LoadServerData" Hover="true" Elevation="3"
              Dense="true" FixedHeader="true" MultiSelection="true" @bind-SelectedItems="_selectedItems"
              OnRowClick="OnRowClick" RowClass="cursor-pointer" Class="rounded-lg">
        <HeaderContent>
            <MudTh><MudTableSortLabel SortLabel="Name" T="Experiment">Name</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="DatabaseConnection" T="Experiment">DB Connection</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="AIConnection" T="Experiment">AI Connection</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="Iterations" T="Experiment">Iterations</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="CreatedAt" T="Experiment">Created</MudTableSortLabel></MudTh>
            <MudTh><MudTableSortLabel SortLabel="ModifiedAt" T="Experiment">Modified</MudTableSortLabel></MudTh>
            <MudTh Style="width: 160px;">Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="DB Connection">
                @if (context.DatabaseConnection != null)
                {
                    <span @onclick:stopPropagation="true">
                        <MudLink Href="@($"/database-connections/{(int)(object)context.DatabaseConnectionId!}")" Color="Color.Primary">
                            @context.DatabaseConnection.Name
                        </MudLink>
                    </span>
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Default">--</MudText>
                }
            </MudTd>
            <MudTd DataLabel="AI Connection">
                @if (context.AIConnection != null)
                {
                    <span @onclick:stopPropagation="true">
                        <MudLink Href="@($"/ai-connections/{(int)(object)context.AIConnectionId!}")" Color="Color.Secondary">
                            @context.AIConnection.Name
                        </MudLink>
                    </span>
                }
                else
                {
                    <MudText Typo="Typo.body2" Color="Color.Default">--</MudText>
                }
            </MudTd>
            <MudTd DataLabel="Iterations">
                <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.ResearchIterations.Count</MudChip>
            </MudTd>
            <MudTd DataLabel="Created">@context.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</MudTd>
            <MudTd DataLabel="Modified">@context.ModifiedAt.ToLocalTime().ToString("yyyy-MM-dd")</MudTd>
            <MudTd @onclick:stopPropagation="true">
                <MudStack Row="true" Spacing="0">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                   OnClick="@(() => Navigation.NavigateTo($"/experiments/{(int)(object)context.Id}/edit"))"
                                   aria-label="Edit" />
                    <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Color="Color.Success" Size="Size.Small"
                                   OnClick="@(() => Navigation.NavigateTo($"/experiments/{(int)(object)context.Id}/research-iterations"))"
                                   aria-label="View research iterations" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                   OnClick="@(() => DeleteSingle(context))" aria-label="Delete" />
                </MudStack>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Typo="Typo.body1" Class="pa-4">No experiments found.</MudText>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 20, 50, 100 }" />
        </PagerContent>
    </MudTable>
</MudContainer>

@code {
    private readonly CancellationTokenSource _pageCts = new();
    private MudTable<Experiment>? _table;
    private HashSet<Experiment> _selectedItems = new();

    public void Dispose()
    {
        _pageCts.Cancel();
        _pageCts.Dispose();
    }

    private Task<TableData<Experiment>> LoadServerData(TableState state, CancellationToken ct) =>
        PageLoadCancellation.RunTableLoadAsync(t => LoadServerDataCore(state, t), _pageCts.Token, ct);

    private async Task<TableData<Experiment>> LoadServerDataCore(TableState state, CancellationToken cancellationToken)
    {
        await using var db = await DbContextFactory.CreateDbContextAsync(cancellationToken);
        IQueryable<Experiment> query = db.Experiments
            .Include(p => p.DatabaseConnection)
            .Include(p => p.AIConnection)
            .Include(p => p.ResearchIterations);

        query = state.SortLabel switch
        {
            "Name" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.Name) : query.OrderBy(x => x.Name),
            "DatabaseConnection" => state.SortDirection == SortDirection.Descending
                ? query.OrderByDescending(x => x.DatabaseConnection != null ? x.DatabaseConnection.Name : "")
                : query.OrderBy(x => x.DatabaseConnection != null ? x.DatabaseConnection.Name : ""),
            "AIConnection" => state.SortDirection == SortDirection.Descending
                ? query.OrderByDescending(x => x.AIConnection != null ? x.AIConnection.Name : "")
                : query.OrderBy(x => x.AIConnection != null ? x.AIConnection.Name : ""),
            "Iterations" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.ResearchIterations.Count) : query.OrderBy(x => x.ResearchIterations.Count),
            "CreatedAt" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.CreatedAt) : query.OrderBy(x => x.CreatedAt),
            "ModifiedAt" => state.SortDirection == SortDirection.Descending ? query.OrderByDescending(x => x.ModifiedAt) : query.OrderBy(x => x.ModifiedAt),
            _ => query.OrderByDescending(x => x.ModifiedAt)
        };

        var totalItems = await query.CountAsync(cancellationToken);
        var items = await query.Skip(state.Page * state.PageSize).Take(state.PageSize).ToListAsync(cancellationToken);

        return new TableData<Experiment> { TotalItems = totalItems, Items = items };
    }

    private async Task DeleteSingle(Experiment item)
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Confirm Delete",
            $"Delete experiment \"{item.Name}\"? All associated research iterations and hypotheses will also be deleted.",
            yesText: "Delete", cancelText: "Cancel");

        if (confirm == true)
        {
            await using var db = await DbContextFactory.CreateDbContextAsync();
            var deleted = await db.Experiments.Where(e => e.Id == item.Id).ExecuteDeleteAsync();
            if (deleted == 0)
                return;
            Snackbar.Add($"Deleted \"{item.Name}\"", Severity.Success);
            await _table!.ReloadServerData();
        }
    }

    private void OnRowClick(TableRowClickEventArgs<Experiment> args) =>
        Navigation.NavigateTo($"/experiments/{(int)(object)args.Item!.Id}/view");

    private async Task DeleteSelected()
    {
        var confirm = await DialogService.ShowMessageBoxAsync(
            "Confirm Delete",
            $"Delete {_selectedItems.Count} experiment(s)? All associated research iterations and hypotheses will also be deleted.",
            yesText: "Delete All", cancelText: "Cancel");

        if (confirm == true)
        {
            var ids = _selectedItems.Select(i => i.Id).ToList();
            await using var db = await DbContextFactory.CreateDbContextAsync();
            var deleted = await db.Experiments.Where(e => ids.Contains(e.Id)).ExecuteDeleteAsync();
            Snackbar.Add(deleted == 0 ? "Nothing deleted" : $"Deleted {deleted} experiment(s)", deleted == 0 ? Severity.Info : Severity.Success);
            _selectedItems.Clear();
            await _table!.ReloadServerData();
        }
    }
}
