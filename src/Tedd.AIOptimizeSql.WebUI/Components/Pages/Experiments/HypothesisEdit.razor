@page "/experiments/{ExperimentId:int}/research-iterations/{IterationId:int}/hypotheses/new"
@page "/experiments/{ExperimentId:int}/research-iterations/{IterationId:int}/hypotheses/{HypothesisId:int}"
@implements IDisposable
@rendermode InteractiveServer
@inject IDbContextFactory<Tedd.AIOptimizeSql.Database.AIOptimizeDbContext> DbContextFactory
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@using Microsoft.EntityFrameworkCore
@using Tedd.AIOptimizeSql.Database
@using Tedd.AIOptimizeSql.Database.Models

<PageTitle>@(_isNew ? "New" : "View") Hypothesis</PageTitle>

<EditNavigationGuard HasUnsavedChanges="@(() => IsModified)"
                     TrySaveAsync="TryPersistAsync"
                     DiscardAsync="DiscardChangesAsync" />

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack" />
        <MudText Typo="Typo.h4">@(_isNew ? "New" : _editMode ? "Edit" : "View") Hypothesis</MudText>
        <MudSpacer />
        @if (!_isNew && !_editMode)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Edit"
                       OnClick="EnterEditMode">
                Edit
            </MudButton>
        }
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_model == null)
    {
        <MudAlert Severity="Severity.Error">Hypothesis not found.</MudAlert>
    }
    else
    {
        @if (_experiment != null)
        {
            <MudCard Elevation="3" Class="rounded-lg mb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Benchmark SQL</MudText>
                        <MudText Typo="Typo.caption">
                            Stored on the experiment; used to measure performance for this research iteration.
                            <MudLink Href="@($"/experiments/{ExperimentId}/edit")" Color="Color.Primary">Open experiment</MudLink>
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pt-0">
                    <SqlMonacoField EditorId="@_benchmarkSqlEditorId"
                                    Label=""
                                    HelperText="SQL used to benchmark performance for hypotheses in this experiment."
                                    @bind-Value="_benchmarkSql"
                                    ReadOnly="@(!_editMode && !_isNew)" />
                </MudCardContent>
            </MudCard>
        }

        @if (!_isNew && !_editMode)
        {
            <MudGrid Class="mb-4">
                <MudItem xs="12" sm="4">
                    <MudPaper Elevation="2" Class="pa-4 rounded-lg d-flex flex-column align-center">
                        @{
                            var pct = _model.ImpovementPercentage;
                            var deltaColor = pct > 0 ? Color.Success : (pct < 0 ? Color.Error : Color.Default);
                        }
                        <MudText Typo="Typo.h4" Color="@deltaColor">
                            @(pct >= 0 ? "+" : "")@pct.ToString("F1")%
                        </MudText>
                        <MudText Typo="Typo.caption">Improvement</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudPaper Elevation="2" Class="pa-4 rounded-lg d-flex flex-column align-center">
                        <MudText Typo="Typo.h4" Color="Color.Info">@FormatTime(_model.TimeUsedMs)</MudText>
                        <MudText Typo="Typo.caption">Time Used</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudPaper Elevation="2" Class="pa-4 rounded-lg d-flex flex-column align-center">
                        <MudText Typo="Typo.h4">@(_iteration?.AiProviderUsed?.ToString() ?? "N/A")</MudText>
                        <MudText Typo="Typo.caption">@(_iteration?.AiModelUsed ?? "No model")</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>

            @if (_model.BenchmarkRunBefore != null || _model.BenchmarkRunAfter != null)
            {
                <MudCard Elevation="3" Class="rounded-lg mb-4">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">Benchmark summary (aggregated)</MudText>
                            <MudText Typo="Typo.caption">Compared on this hypothesis; open each run for full stats, plans, and messages.</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudSimpleTable Dense="true" Class="mb-3">
                            <thead>
                            <tr>
                                <th></th>
                                <th style="text-align:right">Before</th>
                                <th style="text-align:right">After</th>
                                <th style="text-align:right">Δ</th>
                            </tr>
                            </thead>
                            <tbody>
                            <tr>
                                <td><MudText Typo="Typo.body2">Total time (ms)</MudText></td>
                                <td style="text-align:right">@(_model.BenchmarkRunBefore?.TotalTimeMs.ToString() ?? "—")</td>
                                <td style="text-align:right">@(_model.BenchmarkRunAfter?.TotalTimeMs.ToString() ?? "—")</td>
                                <td style="text-align:right">
                                    @if (_benchDeltaTotalMs is int d1)
                                    {
                                        <MudText Color="@(d1 < 0 ? Color.Success : d1 > 0 ? Color.Error : Color.Default)" Typo="Typo.body2">@(d1 > 0 ? "+" : "")@d1</MudText>
                                    }
                                    else { <text>—</text> }
                                </td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.body2">Server elapsed (ms)</MudText></td>
                                <td style="text-align:right">@(_model.BenchmarkRunBefore?.TotalServerElapsedTimeMs.ToString() ?? "—")</td>
                                <td style="text-align:right">@(_model.BenchmarkRunAfter?.TotalServerElapsedTimeMs.ToString() ?? "—")</td>
                                <td style="text-align:right">
                                    @if (_benchDeltaServerElapsedMs is int d2)
                                    {
                                        <MudText Color="@(d2 < 0 ? Color.Success : d2 > 0 ? Color.Error : Color.Default)" Typo="Typo.body2">@(d2 > 0 ? "+" : "")@d2</MudText>
                                    }
                                    else { <text>—</text> }
                                </td>
                            </tr>
                            <tr>
                                <td><MudText Typo="Typo.body2">Logical reads</MudText></td>
                                <td style="text-align:right">@(_model.BenchmarkRunBefore?.TotalLogicalReads.ToString() ?? "—")</td>
                                <td style="text-align:right">@(_model.BenchmarkRunAfter?.TotalLogicalReads.ToString() ?? "—")</td>
                                <td style="text-align:right">
                                    @if (_benchDeltaLogicalReads is int d3)
                                    {
                                        <MudText Color="@(d3 < 0 ? Color.Success : d3 > 0 ? Color.Error : Color.Default)" Typo="Typo.body2">@(d3 > 0 ? "+" : "")@d3</MudText>
                                    }
                                    else { <text>—</text> }
                                </td>
                            </tr>
                            </tbody>
                        </MudSimpleTable>
                        <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                            @if (_model.BenchmarkRunBefore != null)
                            {
                                <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary"
                                           Href="@BenchmarkHref(_model.BenchmarkRunBefore.Id)">
                                    Before benchmark details
                                </MudButton>
                            }
                            @if (_model.BenchmarkRunAfter != null)
                            {
                                <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary"
                                           Href="@BenchmarkHref(_model.BenchmarkRunAfter.Id)">
                                    After benchmark details
                                </MudButton>
                            }
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            }
        }

        @if (!_isNew && !_editMode && _hypothesisLogs.Count > 0)
        {
            <MudCard Elevation="3" Class="rounded-lg mb-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Activity log</MudText>
                        <MudText Typo="Typo.caption">Generation and worker steps recorded for this hypothesis.</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pt-0">
                    <MudStack Spacing="2">
                        @foreach (var line in _hypothesisLogs)
                        {
                            <MudPaper Elevation="0" Class="pa-2 rounded" Style="background: var(--mud-palette-background-grey);">
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                    @line.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
                                    @if (!string.IsNullOrEmpty(line.Source))
                                    {
                                        <text> · @line.Source</text>
                                    }
                                </MudText>
                                <MudText Typo="Typo.body2" Style="white-space: pre-wrap; word-break: break-word;">@line.Message</MudText>
                            </MudPaper>
                        }
                    </MudStack>
                </MudCardContent>
            </MudCard>
        }

        <MudCard Elevation="3" Class="rounded-lg">
            <MudCardContent>
                <MudForm @ref="_form" @bind-IsValid="_formValid">
                    <MudTextField @bind-Value="_model.Description" Label="Hypothesis"
                                  Lines="4" Variant="Variant.Outlined" Class="mb-4"
                                  ReadOnly="@(!_editMode && !_isNew)" />

                    <MudNumericField @bind-Value="_model.ImpovementPercentage" Label="Improvement %"
                                     Variant="Variant.Outlined" Class="mb-4"
                                     HelperText="Set after a run. Positive = improvement, negative = regression."
                                     ReadOnly="true" />

                    <MudNumericField @bind-Value="_model.TimeUsedMs" Label="Time Used (ms)"
                                     Variant="Variant.Outlined" Class="mb-4"
                                     HelperText="Set automatically after a benchmark run."
                                     ReadOnly="true" />

                    <MudSelect T="HypothesisId?" @bind-Value="_selectedBuildsOn"
                               Label="Builds On Hypothesis" Variant="Variant.Outlined" Class="mb-4"
                               Clearable="true" ReadOnly="@(!_editMode && !_isNew)">
                        @foreach (var h in _otherHypotheses)
                        {
                            <MudSelectItem Value="@((HypothesisId?)h.Id)">
                                #@((int)(object)h.Id) - @(h.Description?.Length > 50 ? h.Description[..50] + "..." : h.Description ?? "(no text)")
                            </MudSelectItem>
                        }
                    </MudSelect>

                    @if (!_isNew)
                    {
                        <MudText Typo="Typo.caption">
                            Created: @_model.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                        </MudText>
                    }
                </MudForm>
            </MudCardContent>

            @if (_editMode || _isNew)
            {
                <MudCardActions Class="pa-4">
                    <MudSpacer />
                    <MudButton Variant="Variant.Text" OnClick="GoBack" Class="mr-2">Cancel</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               OnClick="Save" StartIcon="@Icons.Material.Filled.Save">
                        Save
                    </MudButton>
                </MudCardActions>
            }
        </MudCard>

        @if (!_isNew && _model.BuildsOnHypothesisId.HasValue)
        {
            <MudAlert Severity="Severity.Info" Class="mt-4">
                This hypothesis builds on
                <MudLink Href="@($"/experiments/{ExperimentId}/research-iterations/{IterationId}/hypotheses/{(int)(object)_model.BuildsOnHypothesisId}")"
                         Color="Color.Primary">
                    Hypothesis #@((int)(object)_model.BuildsOnHypothesisId)
                </MudLink>
            </MudAlert>
        }
    }
</MudContainer>

@code {
    [Parameter] public int ExperimentId { get; set; }
    [Parameter] public int IterationId { get; set; }
    [Parameter] public int? HypothesisId { get; set; }

    private Hypothesis? _model;
    private ResearchIteration? _iteration;
    private Experiment? _experiment;
    private string? _benchmarkSql;
    private string _benchmarkSqlEditorId = "";
    private bool _isNew;
    private bool _editMode;
    private bool _loading = true;
    private bool _formValid;
    private MudForm? _form;
    private HypothesisId? _selectedBuildsOn;
    private List<Hypothesis> _otherHypotheses = new();
    private int? _benchDeltaTotalMs;
    private int? _benchDeltaServerElapsedMs;
    private int? _benchDeltaLogicalReads;
    private List<HypothesisLog> _hypothesisLogs = new();
    private readonly CancellationTokenSource _pageCts = new();
    private AIOptimizeDbContext? _db;

    private string _baselineDescription = "";
    private string _baselineBenchmarkSql = "";
    private HypothesisId? _baselineBuildsOn;

    private bool IsModified =>
        _model != null && !_loading && (_isNew || _editMode) &&
        ((_model.Description ?? "") != _baselineDescription ||
         (_benchmarkSql ?? "") != _baselineBenchmarkSql ||
         _selectedBuildsOn != _baselineBuildsOn);

    private void CaptureBaseline()
    {
        if (_model == null) return;
        _baselineDescription = _model.Description ?? "";
        _baselineBenchmarkSql = _benchmarkSql ?? "";
        _baselineBuildsOn = _selectedBuildsOn;
    }

    private void EnterEditMode()
    {
        _editMode = true;
        CaptureBaseline();
    }

    public void Dispose()
    {
        _pageCts.Cancel();
        _pageCts.Dispose();
        _db?.Dispose();
        _db = null;
    }

    protected override Task OnInitializedAsync() =>
        PageLoadCancellation.RunPageLoadAsync(async ct =>
        {
            _db = await DbContextFactory.CreateDbContextAsync(ct);
            var iterationId = (ResearchIterationId)(object)IterationId;

            _iteration = await _db.ResearchIterations.AsTracking()
                .Include(b => b.Experiment)
                .FirstOrDefaultAsync(b => b.Id == iterationId, ct);

            _experiment = _iteration?.Experiment;
            _benchmarkSql = _experiment?.BenchmarkSql;
            _benchmarkSqlEditorId = $"hypothesis-benchmark-sql-e{ExperimentId}-i{IterationId}";

            _otherHypotheses = await _db.Hypotheses.AsNoTracking()
                .Where(h => h.ResearchIterationId == iterationId)
                .OrderBy(h => h.Id)
                .ToListAsync(ct);

            if (HypothesisId.HasValue)
            {
                _isNew = false;
                var hId = (HypothesisId)(object)HypothesisId.Value;
                _model = await _db.Hypotheses.AsTracking()
                    .Include(h => h.BenchmarkRunBefore)
                    .Include(h => h.BenchmarkRunAfter)
                    .Include(h => h.Logs)
                    .FirstOrDefaultAsync(h => h.Id == hId, ct);

                if (_model != null)
                {
                    _selectedBuildsOn = _model.BuildsOnHypothesisId;
                    _otherHypotheses = _otherHypotheses.Where(h => h.Id != _model.Id).ToList();
                    _hypothesisLogs = _model.Logs.OrderBy(l => l.CreatedAt).ThenBy(l => l.Id).ToList();
                    ComputeBenchDeltas();
                }
            }
            else
            {
                _isNew = true;
                _editMode = true;
                _model = new Hypothesis
                {
                    ResearchIterationId = iterationId
                };
            }
            _loading = false;
            CaptureBaseline();
        }, _pageCts.Token);

    private string FormatTime(long ms)
    {
        if (ms < 1000) return $"{ms}ms";
        if (ms < 60000) return $"{ms / 1000.0:F1}s";
        return $"{ms / 60000.0:F1}m";
    }

    private void ComputeBenchDeltas()
    {
        _benchDeltaTotalMs = null;
        _benchDeltaServerElapsedMs = null;
        _benchDeltaLogicalReads = null;
        if (_model?.BenchmarkRunBefore == null || _model.BenchmarkRunAfter == null)
            return;
        var b = _model.BenchmarkRunBefore;
        var a = _model.BenchmarkRunAfter;
        _benchDeltaTotalMs = a.TotalTimeMs - b.TotalTimeMs;
        _benchDeltaServerElapsedMs = a.TotalServerElapsedTimeMs - b.TotalServerElapsedTimeMs;
        _benchDeltaLogicalReads = a.TotalLogicalReads - b.TotalLogicalReads;
    }

    private string BenchmarkHref(BenchmarkRunId id) =>
        $"/experiments/{ExperimentId}/research-iterations/{IterationId}/benchmarks/{(int)(object)id}";

    private async Task<bool> TryPersistAsync()
    {
        if (_db is null || _model == null) return false;
        await _form!.ValidateAsync();
        if (!_formValid) return false;

        _model.BuildsOnHypothesisId = _selectedBuildsOn;

        if (_experiment != null && (_isNew || _editMode))
            _experiment.BenchmarkSql = _benchmarkSql;

        if (_isNew)
        {
            _model.CreatedAt = DateTime.UtcNow;
            _db.Hypotheses.Add(_model);
        }

        await _db.SaveChangesAsync();
        Snackbar.Add(_isNew ? "Hypothesis created" : "Hypothesis saved", Severity.Success);
        if (!_isNew)
            _editMode = false;
        ComputeBenchDeltas();
        CaptureBaseline();
        return true;
    }

    private async Task Save()
    {
        if (!await TryPersistAsync()) return;
        Navigation.NavigateTo($"/experiments/{ExperimentId}/research-iterations/{IterationId}");
    }

    private async Task DiscardChangesAsync()
    {
        if (_db is null || _model == null) return;
        var iterationId = (ResearchIterationId)(object)IterationId;

        if (_isNew)
        {
            _model = new Hypothesis { ResearchIterationId = iterationId };
            _selectedBuildsOn = null;
            _benchmarkSql = _experiment?.BenchmarkSql;
            _otherHypotheses = await _db.Hypotheses.AsNoTracking()
                .Where(h => h.ResearchIterationId == iterationId)
                .OrderBy(h => h.Id)
                .ToListAsync(_pageCts.Token);
        }
        else
        {
            var hId = _model.Id;
            _db.Entry(_model).State = EntityState.Detached;
            _model = await _db.Hypotheses.AsTracking()
                .Include(h => h.BenchmarkRunBefore)
                .Include(h => h.BenchmarkRunAfter)
                .Include(h => h.Logs)
                .FirstOrDefaultAsync(h => h.Id == hId, _pageCts.Token);
            if (_model == null)
            {
                Snackbar.Add("Hypothesis not found.", Severity.Error);
                return;
            }

            _hypothesisLogs = _model.Logs.OrderBy(l => l.CreatedAt).ThenBy(l => l.Id).ToList();
            _selectedBuildsOn = _model.BuildsOnHypothesisId;
            _benchmarkSql = _experiment?.BenchmarkSql;
            _editMode = false;
            _otherHypotheses = await _db.Hypotheses.AsNoTracking()
                .Where(h => h.ResearchIterationId == iterationId && h.Id != _model.Id)
                .OrderBy(h => h.Id)
                .ToListAsync(_pageCts.Token);
            ComputeBenchDeltas();
        }

        CaptureBaseline();
        await InvokeAsync(StateHasChanged);
    }

    private void GoBack() => Navigation.NavigateTo($"/experiments/{ExperimentId}/research-iterations/{IterationId}");
}
