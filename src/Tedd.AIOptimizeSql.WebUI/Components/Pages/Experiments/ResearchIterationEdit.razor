@page "/research-iterations/new"
@page "/research-iterations/{IterationId:int}/edit"
@page "/experiments/{ExperimentId:int}/research-iterations/new"
@page "/experiments/{ExperimentId:int}/research-iterations/{IterationId:int}/edit"
@implements IDisposable
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Tedd.AIOptimizeSql.Database
@using Tedd.AIOptimizeSql.Database.DataAccess
@using Tedd.AIOptimizeSql.Database.Models
@using Tedd.AIOptimizeSql.Database.Models.Enums
@inject IDbContextFactory<AIOptimizeDbContext> DbContextFactory
@inject IAIOptimizeDataAccess DataAccess
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>@(_isNew ? "New" : "Edit") research iteration</PageTitle>

<EditNavigationGuard HasUnsavedChanges="@(() => IsModified)"
                     TrySaveAsync="TryPersistAsync"
                     DiscardAsync="DiscardChangesAsync" />

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-4">
    <MudStack Row="true" AlignItems="AlignItems.Center" Class="mb-4">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack" />
        <MudText Typo="Typo.h4">@(_isNew ? "New" : "Edit") research iteration</MudText>
    </MudStack>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
    }
    else if (_isNew && _experiments.Count == 0)
    {
        <MudAlert Severity="Severity.Warning" Class="mb-4">
            Create an experiment before adding a research iteration.
            <MudLink Href="/experiments/new" Color="Color.Primary">New experiment</MudLink>
        </MudAlert>
    }
    else if (!_isNew && _iteration == null)
    {
        <MudAlert Severity="Severity.Error">Research iteration not found.</MudAlert>
    }
    else
    {
        <MudCard Elevation="3" Class="rounded-lg">
            <MudCardContent>
                <MudForm @ref="_form" @bind-IsValid="_formValid">
                    @if (_isNew && !ExperimentIdFromRoute.HasValue)
                    {
                        <MudSelect T="ExperimentId?" @bind-Value="_selectedExperimentId" Label="Experiment"
                                   Variant="Variant.Outlined" Class="mb-4" Required="true"
                                   RequiredError="Choose an experiment">
                            @foreach (var e in _experiments)
                            {
                                <MudSelectItem Value="@((ExperimentId?)e.Id)">@e.Name</MudSelectItem>
                            }
                        </MudSelect>
                    }
                    else if (_isNew && ExperimentIdFromRoute.HasValue)
                    {
                        <MudText Typo="Typo.body1" Class="mb-4">
                            Experiment: <strong>@_experimentName</strong>
                        </MudText>
                    }
                    else if (_iteration != null)
                    {
                        <MudText Typo="Typo.body1" Class="mb-2">
                            Experiment:
                            <MudLink Href="@($"/experiments/{(int)(object)_iteration.ExperimentId}/edit")">@_iteration.Experiment?.Name</MudLink>
                        </MudText>
                        <MudDivider Class="mb-4" />
                        <MudStack Spacing="2" Class="mb-4">
                            <MudText Typo="Typo.subtitle2">Status</MudText>
                            <MudText Typo="Typo.body2">State: <strong>@_iteration.State</strong></MudText>
                            <MudText Typo="Typo.body2">Started: @FormatNullable(_iteration.StartedAt)</MudText>
                            <MudText Typo="Typo.body2">Ended: @FormatNullable(_iteration.EndedAt)</MudText>
                            <MudText Typo="Typo.body2">Last message: @(_iteration.LastMessage ?? "—")</MudText>
                            <MudText Typo="Typo.body2">
                                AI snapshot: @(_iteration.AiProviderUsed?.ToString() ?? "—") / @(_iteration.AiModelUsed ?? "—")
                                @if (_iteration.AIConnection is { } ac)
                                {
                                    <text> (</text>
                                    <MudLink Href="@($"/ai-connections/{(int)(object)ac.Id}")">@ac.Name</MudLink>
                                    <text>)</text>
                                }
                            </MudText>
                        </MudStack>
                    }

                    <MudTextField @bind-Value="_hints" Label="Hints" Lines="3" Variant="Variant.Outlined" Class="mb-4"
                                  HelperText="Optional guidance for the optimizer" />

                    <MudNumericField @bind-Value="_maxHypotheses" Label="Max number of hypotheses" Variant="Variant.Outlined"
                                     Min="1" Max="10000" Class="mb-4" Required="true" />
                </MudForm>

                @if (!_isNew && _iteration != null)
                {
                    @if (_iteration.BaselineBenchmarkRunId.HasValue)
                    {
                        <MudDivider Class="my-4" />
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Baseline Benchmark</MudText>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary"
                                   Href="@($"/experiments/{(int)(object)_iteration.ExperimentId}/research-iterations/{(int)(object)_iteration.Id}/benchmarks/{(int)(object)_iteration.BaselineBenchmarkRunId}")">
                            View baseline benchmark
                        </MudButton>
                    }

                    @if (!string.IsNullOrWhiteSpace(_iteration.SchemaDiscoveryMarkdown))
                    {
                        <MudDivider Class="my-4" />
                        <MudExpansionPanels Class="mb-2">
                            <MudExpansionPanel Text="Schema Discovery Output" Expanded="false">
                                <MudPaper Class="pa-3" Elevation="0" Outlined="true" Style="max-height:600px;overflow:auto;">
                                    <pre style="white-space:pre-wrap;word-break:break-word;margin:0;font-size:0.85rem;">@_iteration.SchemaDiscoveryMarkdown</pre>
                                </MudPaper>
                            </MudExpansionPanel>
                        </MudExpansionPanels>
                    }
                }
            </MudCardContent>
            <MudCardActions Class="pa-4 flex-wrap" Style="gap: 8px;">
                @if (!_isNew && _iteration != null)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.List"
                               Href="@($"/experiments/{(int)(object)_iteration.ExperimentId}/research-iterations/{(int)(object)_iteration.Id}")">
                        View hypotheses
                    </MudButton>
                    @if (_iteration.State == ResearchIterationState.Stopped)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Info" StartIcon="@Icons.Material.Filled.Queue"
                                   OnClick="@(() => SetState(ResearchIterationState.Queued))" Disabled="@_busy">
                            Queue
                        </MudButton>
                    }
                    @if (_iteration.State == ResearchIterationState.Queued)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Stop"
                                   OnClick="@(() => SetState(ResearchIterationState.Stopped))" Disabled="@_busy">
                            Stop
                        </MudButton>
                    }
                    @if (_iteration.State == ResearchIterationState.Paused)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Success" StartIcon="@Icons.Material.Filled.PlayArrow"
                                   OnClick="@(() => SetState(ResearchIterationState.Queued))" Disabled="@_busy">
                            Resume
                        </MudButton>
                    }
                    @if (_iteration.State == ResearchIterationState.Running)
                    {
                        <MudButton Variant="Variant.Outlined" Color="Color.Warning" StartIcon="@Icons.Material.Filled.Pause"
                                   OnClick="@(() => SetState(ResearchIterationState.Paused))" Disabled="@_busy">
                            Pause
                        </MudButton>
                        <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Stop"
                                   OnClick="@(() => SetState(ResearchIterationState.Stopped))" Disabled="@_busy">
                            Stop
                        </MudButton>
                    }
                }
                <MudSpacer />
                <MudButton Variant="Variant.Text" OnClick="GoBack" Disabled="@_busy">Cancel</MudButton>
                @if (_isNew)
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!_formValid || _busy)"
                               OnClick="@(() => SaveAsync(runAfter: false))" StartIcon="@Icons.Material.Filled.Save">
                        Save
                    </MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Success" Disabled="@(!_formValid || _busy)"
                               OnClick="@(() => SaveAsync(runAfter: true))" StartIcon="@Icons.Material.Filled.PlayArrow">
                        Save and run
                    </MudButton>
                }
                else
                {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="@(!_formValid || _busy)"
                               OnClick="@(() => SaveAsync(runAfter: false))" StartIcon="@Icons.Material.Filled.Save">
                        Save
                    </MudButton>
                }
            </MudCardActions>
        </MudCard>
    }
</MudContainer>

@code {
    [Parameter] public int? ExperimentId { get; set; }
    [Parameter] public int? IterationId { get; set; }

    private ResearchIteration? _iteration;
    private bool _isNew;
    private bool _loading = true;
    private bool _busy;
    private bool _formValid;
    private MudForm? _form;
    private string? _hints;
    private int _maxHypotheses = 10;
    private List<Experiment> _experiments = new();
    private ExperimentId? _selectedExperimentId;
    private string _experimentName = "";

    private int? ExperimentIdFromRoute => ExperimentId;

    private string? _baselineHints;
    private int _baselineMaxHypotheses;
    private ExperimentId? _baselineSelectedExperimentId;

    private bool IsModified =>
        !_loading &&
        ((_hints ?? "") != (_baselineHints ?? "") ||
         _maxHypotheses != _baselineMaxHypotheses ||
         (_isNew && !ExperimentIdFromRoute.HasValue && _selectedExperimentId != _baselineSelectedExperimentId));

    private void CaptureBaseline()
    {
        _baselineHints = _hints;
        _baselineMaxHypotheses = _maxHypotheses;
        _baselineSelectedExperimentId = _selectedExperimentId;
    }

    private CancellationTokenSource? _loadCts;

    private CancellationToken StartNewLoad()
    {
        _loadCts?.Cancel();
        _loadCts?.Dispose();
        _loadCts = new CancellationTokenSource();
        return _loadCts.Token;
    }

    public void Dispose()
    {
        _loadCts?.Cancel();
        _loadCts?.Dispose();
    }

    protected override async Task OnParametersSetAsync()
    {
        var ct = StartNewLoad();
        _loading = true;
        _iteration = null;
        _isNew = !IterationId.HasValue;

        try
        {
            await using var db = await DbContextFactory.CreateDbContextAsync(ct);
            _experiments = await db.Experiments.AsNoTracking().OrderBy(e => e.Name).ToListAsync(ct);

            if (_isNew)
            {
                if (ExperimentIdFromRoute.HasValue)
                {
                    var eid = (ExperimentId)(object)ExperimentIdFromRoute.Value;
                    var exp = _experiments.FirstOrDefault(e => e.Id == eid);
                    _selectedExperimentId = eid;
                    _experimentName = exp?.Name ?? $"#{ExperimentIdFromRoute.Value}";
                }
                else
                    _selectedExperimentId = _experiments.FirstOrDefault()?.Id;
            }
            else
            {
                var iid = (ResearchIterationId)(object)IterationId!.Value;
                _iteration = await DataAccess.GetResearchIterationForEditAsync(iid, ct);
                if (_iteration != null)
                {
                    if (ExperimentIdFromRoute.HasValue)
                    {
                        var expected = (ExperimentId)(object)ExperimentIdFromRoute.Value;
                        if (_iteration.ExperimentId != expected)
                        {
                            _iteration = null;
                            Snackbar.Add("Research iteration does not belong to this experiment.", Severity.Error);
                        }
                    }

                    if (_iteration != null)
                    {
                        _hints = _iteration.Hints;
                        _maxHypotheses = _iteration.MaxNumberOfHypotheses;
                    }
                }
            }
        }
        catch (OperationCanceledException)
        {
        }
        finally
        {
            if (!ct.IsCancellationRequested)
            {
                _loading = false;
                CaptureBaseline();
            }
        }
    }

    private static string FormatNullable(DateTime? utc) =>
        utc.HasValue ? utc.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : "—";

    private ExperimentId? ResolveExperimentIdForCreate()
    {
        if (ExperimentIdFromRoute.HasValue)
            return (ExperimentId)(object)ExperimentIdFromRoute.Value;
        return _selectedExperimentId;
    }

    private async Task<ResearchIterationId?> CreateIterationCoreAsync()
    {
        var expId = ResolveExperimentIdForCreate();
        if (expId is null)
        {
            Snackbar.Add("Select an experiment.", Severity.Warning);
            return null;
        }

        return await DataAccess.CreateResearchIterationAsync(expId.Value, _hints, _maxHypotheses);
    }

    private async Task<bool> TryPersistAsync()
    {
        await _form!.ValidateAsync();
        if (!_formValid || _busy) return false;

        _busy = true;
        try
        {
            if (_isNew)
            {
                var newId = await CreateIterationCoreAsync();
                if (newId is null) return false;
                Snackbar.Add("Research iteration created", Severity.Success);
                CaptureBaseline();
                return true;
            }

            if (_iteration != null)
            {
                await DataAccess.UpdateResearchIterationEditableFieldsAsync(_iteration.Id, _hints, _maxHypotheses);
                Snackbar.Add("Saved", Severity.Success);
                _iteration = await DataAccess.GetResearchIterationForEditAsync(_iteration.Id);
                CaptureBaseline();
                return true;
            }

            return false;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task DiscardChangesAsync()
    {
        if (_isNew)
        {
            _hints = null;
            _maxHypotheses = 10;
            if (!ExperimentIdFromRoute.HasValue)
                _selectedExperimentId = _experiments.FirstOrDefault()?.Id;
        }
        else if (_iteration != null)
        {
            _iteration = await DataAccess.GetResearchIterationForEditAsync(_iteration.Id);
            if (_iteration != null)
            {
                _hints = _iteration.Hints;
                _maxHypotheses = _iteration.MaxNumberOfHypotheses;
            }
        }

        CaptureBaseline();
        await InvokeAsync(StateHasChanged);
    }

    private async Task SaveAsync(bool runAfter)
    {
        await _form!.ValidateAsync();
        if (!_formValid || _busy) return;

        _busy = true;
        try
        {
            if (_isNew)
            {
                var newId = await CreateIterationCoreAsync();
                if (newId is not ResearchIterationId createdId) return;
                if (runAfter)
                    await DataAccess.BeginResearchIterationRunAsync(createdId);

                Snackbar.Add(runAfter ? "Research iteration created and run started" : "Research iteration created", Severity.Success);
                Navigation.NavigateTo($"/research-iterations/{(int)(object)createdId}/edit");
            }
            else if (_iteration != null)
            {
                await DataAccess.UpdateResearchIterationEditableFieldsAsync(_iteration.Id, _hints, _maxHypotheses);
                Snackbar.Add("Saved", Severity.Success);
                _iteration = await DataAccess.GetResearchIterationForEditAsync(_iteration.Id);
                CaptureBaseline();
            }
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SetState(ResearchIterationState state)
    {
        if (_iteration == null || _busy) return;
        _busy = true;
        try
        {
            await DataAccess.SetResearchIterationStateAsync(_iteration.Id, state);
            _iteration = await DataAccess.GetResearchIterationForEditAsync(_iteration.Id);
            Snackbar.Add($"State set to {state}", Severity.Info);
        }
        finally
        {
            _busy = false;
        }
    }

    private void GoBack()
    {
        if (ExperimentIdFromRoute.HasValue)
            Navigation.NavigateTo($"/experiments/{ExperimentIdFromRoute.Value}/research-iterations");
        else
            Navigation.NavigateTo("/research-iterations");
    }
}
